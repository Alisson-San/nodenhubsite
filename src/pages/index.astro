			timeline.addLabel("inicio", 0);
			timeline.addLabel("quem-somos", 4.5);
			timeline.addLabel("home", 7.28);
			timeline.addLabel("game", 9.82);
			timeline.addLabel("data", 12.35);
			timeline.addLabel("contato", 17.18);

			const menuTargetTimes: Record<string, number> = {
				inicio: 0,

				// Marca, proposta, cidades e três segmentos já visíveis.
				"quem-somos": 5.9,

				// Ícone e painel Home completamente apresentados.
				home: 8.2,

				// Ícone e painel Game completamente apresentados.
				game: 10.75,

				// Ícone e painel Data completamente apresentados.
				data: 13.3,

				// Tratado separadamente para ir ao fim real.
				contato: timeline.duration(),
			};

			const header = document.querySelector<HTMLElement>("#site-header");
			const menuToggle = document.querySelector<HTMLButtonElement>("#menu-toggle");
			const navigation = document.querySelector<HTMLElement>("#site-navigation");

			const navigationLinks = Array.from(
				document.querySelectorAll<HTMLAnchorElement>(
					"[data-timeline-label]",
				),
			);

			const setActiveNavigation = (activeLabel: string) => {
				navigationLinks.forEach((link) => {
					link.classList.toggle(
						"is-active",
						link.dataset.timelineLabel === activeLabel,
					);
				});
			};

			const getCurrentTimelineLabel = () => {
				const currentTime = timeline.time();
				const orderedLabels = [
					{ name: "inicio", time: timeline.labels.inicio },
					{ name: "quem-somos", time: timeline.labels["quem-somos"] },
					{ name: "home", time: timeline.labels.home },
					{ name: "game", time: timeline.labels.game },
					{ name: "data", time: timeline.labels.data },
					{ name: "contato", time: timeline.labels.contato },
				];

				let currentLabel = "inicio";

				orderedLabels.forEach((label) => {
					if (currentTime >= label.time - 0.25) {
						currentLabel = label.name;
					}
				});

				return currentLabel;
			};

			const closeMobileMenu = () => {
				header?.classList.remove("is-menu-open");
				menuToggle?.setAttribute("aria-expanded", "false");
				menuToggle?.setAttribute("aria-label", "Abrir menu");
			};

			const scrollToTimelineLabel = (label: string) => {
				const trigger = timeline.scrollTrigger;

				if (!trigger) return;

				if (label === "contato") {
					lenis.scrollTo(trigger.end, {
						duration: 1.5,
					});

					return;
				}

				const targetTime = menuTargetTimes[label];

				if (typeof targetTime !== "number") return;

				const progress = targetTime / timeline.duration();

				const destination =
					trigger.start + (trigger.end - trigger.start) * progress;

				lenis.scrollTo(destination, {
					duration: 1.35,
				});
			};

			document
				.querySelectorAll<HTMLAnchorElement>("[data-timeline-label]")
				.forEach((link) => {
					link.addEventListener("click", (event) => {
						event.preventDefault();

						const label = link.dataset.timelineLabel;
						if (!label) return;

						closeMobileMenu();
						scrollToTimelineLabel(label);
					});
				});


			menuToggle?.addEventListener("click", () => {
				const isOpen = header?.classList.toggle("is-menu-open") ?? false;

				menuToggle.setAttribute("aria-expanded", String(isOpen));
				menuToggle.setAttribute(
					"aria-label",
					isOpen ? "Fechar menu" : "Abrir menu",
				);
			});

			timeline.eventCallback("onUpdate", () => {
				setActiveNavigation(getCurrentTimelineLabel());
			});

			lenis.on("scroll", (event: { scroll: number }) => {
				header?.classList.toggle("is-scrolled", event.scroll > 24);
				setActiveNavigation(getCurrentTimelineLabel());
			});

			window.addEventListener("resize", () => {
				closeMobileMenu();
				placeIntroNodes();
				ScrollTrigger.refresh();
			});

			setActiveNavigation("inicio");
		</script>
