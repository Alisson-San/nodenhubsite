---
import NodenSymbol from "../components/NodenSymbol.astro";
import NodenMarkStatic from "../components/NodenMarkStatic-conectores-visiveis.astro";
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="Noden Technology Hub — tecnologia, performance e dados conectados."
		/>
		<title>NODEN — Technology Hub</title>

		<script is:inline>
			(() => {
				const mobileBreakpoint = 820;
				const currentPath = window.location.pathname.replace(/\/$/, "");

				if (
					window.innerWidth <= mobileBreakpoint &&
					currentPath !== "/mobile"
				) {
					window.location.replace(
						`/mobile${window.location.search}${window.location.hash}`,
					);
				}
			})();
		</script>

	</head>

	<body>

		<header id="site-header" class="site-header">
			<a
				href="#inicio"
				class="site-logo"
				data-timeline-label="inicio"
				aria-label="Noden — voltar ao início"
			>
				<span>N</span>

				<span class="site-logo-mark" aria-hidden="true">
					<NodenMarkStatic idPrefix="header-noden-mark" />
				</span>

				<span>DEN</span>
			</a>

			<button
				id="menu-toggle"
				class="menu-toggle"
				type="button"
				aria-expanded="false"
				aria-controls="site-navigation"
				aria-label="Abrir menu"
			>
				<span></span>
				<span></span>
			</button>

			<nav id="site-navigation" class="site-navigation" aria-label="Navegação principal">
				<a href="#quem-somos" data-timeline-label="quem-somos">Quem somos</a>
				<a href="#noden-home" data-timeline-label="home">Noden Home</a>
				<a href="#noden-game" data-timeline-label="game">Noden Game</a>
				<a href="#noden-data" data-timeline-label="data">Noden Data</a>
				<a href="#contato" class="navigation-contact" data-timeline-label="contato">Contato</a>
			</nav>
		</header>

		<main class="experience">
			<section class="scroll-stage">
				<div class="scene">
					<div class="ambient ambient-one"></div>
					<div class="ambient ambient-two"></div>

					<NodenSymbol />

					<div id="brand-scene" class="brand-scene">
						<div class="brand-lockup" aria-label="NODEN Technology Hub">
							<div class="brand-word">
								<span class="brand-letter brand-letter-n">N</span>
								<span
									id="brand-symbol-slot"
									class="brand-symbol-slot"
									aria-hidden="true"
								></span>
								<span class="brand-letter brand-letter-den">DEN</span>
							</div>

							<span class="brand-subtitle">TECHNOLOGY HUB</span>
						</div>

						<div id="about-copy" class="about-copy">
							<div class="about-marker">
								<span class="about-index">01</span>
								<span class="about-eyebrow">QUEM SOMOS</span>
								<span class="about-line" aria-hidden="true"></span>
							</div>

							<div class="about-content">
								<div class="about-heading">
									<span class="about-kicker">UM HUB. TRÊS FRENTES.</span>

									<h2>
										Tecnologia para
										<span> pessoas, performance e dados.</span>
									</h2>

									<p class="about-lead">
										A Noden reúne serviços complementares para resolver desde
										o suporte do dia a dia até projetos de alta performance e
										inteligência de dados.
									</p>
									<div
										class="about-coverage"
										aria-label="Cidades com atendimento domiciliar"
									>
										<span class="coverage-label">ATENDIMENTO DOMICILIAR</span>

										<div class="coverage-cities">
											<span>Barão</span>
											<span>Carlos Barbosa</span>
											<span>Salvador do Sul</span>
											<span>São Pedro da Serra</span>
										</div>
									</div>
								</div>

								<div class="about-services" aria-label="Segmentos da Noden">
									<article class="service-card service-home">
										<span class="service-number">01</span>
										<h3>Noden Home</h3>
										<p>
											Suporte, manutenção, upgrades e soluções para a
											tecnologia do dia a dia.
										</p>
									</article>

									<article class="service-card service-game">
										<span class="service-number">02</span>
										<h3>Noden Game</h3>
										<p>
											Montagem, otimização e upgrades para setups que precisam
											entregar mais.
										</p>
									</article>

									<article class="service-card service-data">
										<span class="service-number">03</span>
										<h3>Noden Data</h3>
										<p>
											Engenharia de dados, BI, analytics e soluções de software para transformar
											informação em decisão.
										</p>
									</article>
								</div>
							</div>
						</div>
					</div>

					<div id="start-copy" class="copy start-copy">
						<span class="start-kicker">NODEN TECHNOLOGY HUB</span>

						<h1>BEM-VINDO</h1>

						<p class="start-message">
							<strong>A tecnologia nos conecta.</strong>
							<span>A Noden transforma essa conexão.</span>
						</p>
					</div>

					<div class="division-shell">
						<div id="home-copy" class="copy division-copy division-home">
							<span class="division-kicker">NODEN HOME</span>
							<h2>Suporte técnico presencial para sua casa.</h2>
							<p class="division-lead">
								Atendimento residencial com deslocamento até o local para
								resolver problemas, instalar equipamentos e orientar você com
								clareza.
							</p>

							<ul class="division-list">
								<li>Instalação e configuração de equipamentos</li>
								<li>Limpeza, formatação e otimização do sistema</li>
								<li>Upgrades básicos de memória e SSD</li>
								<li>Consultoria gratuita para dúvidas e problemas</li>
							</ul>

							<p class="division-meta">
								Atendimento local · Diagnóstico · Solução prática
							</p>
						</div>
					</div>

					<div class="division-shell">
						<div id="game-copy" class="copy division-copy division-game">
							<span class="division-kicker">NODEN GAME</span>
							<h2>Setup gamer pensado em otimização.</h2>
							<p class="division-lead">
								Para quem quer montar, revisar ou evoluir o setup com foco em
								desempenho, estabilidade e melhor escolha de hardware.
							</p>

							<ul class="division-list">
								<li>Montagem e revisão completa do setup gamer</li>
								<li>Diagnóstico de desempenho e gargalos</li>
								<li>Upgrades de hardware e refrigeração</li>
								<li>Consultoria para peças, compatibilidade e custo-benefício</li>
							</ul>

							<p class="division-meta">
								Hardware · Performance · Otimização
							</p>
						</div>
					</div>

					<div class="division-shell">
						<div id="data-copy" class="copy division-copy division-data">
							<span class="division-kicker">NODEN DATA</span>
							<h2>Dados organizados para apoiar decisões reais.</h2>
							<p class="division-lead">
								Soluções para estruturar informações, automatizar análises e
								transformar dados em visão de negócio.
							</p>

							<ul class="division-list">
								<li>Dashboards, indicadores e visualização de resultados</li>
								<li>Soluções de Software, evoluindo processos.</li>
								<li>Integração, tratamento e organização de dados</li>
								<li>Automação de relatórios e fluxos analíticos</li>
								<li>BI, analytics e apoio à tomada de decisão</li>
							</ul>

							<p class="division-meta">
								Data Engineering · BI · Analytics · Developer
							</p>
						</div>
					</div>

					<div id="final-copy" class="copy final-copy">
						<div class="final-demand">
							<h2>
								<span class="final-demand-line final-demand-line-one">
									Várias demandas
								</span>

								<span class="final-demand-line final-demand-line-two">
									Um só lugar.
								</span>
							</h2>
						</div>

						<div class="final-brand-lockup" aria-label="NODEN">
							<span class="final-brand-letter final-brand-letter-n">N</span>

							<span
								id="final-symbol-slot"
								class="final-symbol-slot"
								aria-hidden="true"
							></span>

							<span class="final-brand-letter final-brand-letter-den">DEN</span>
						</div>

						<a href="whatsapp://send?phone=5554996306632&text=Ol%C3%A1%21%20Vim%20pelo%20site%20da%20Noden." rel="noopener noreferrer" class="final-contact-link" aria-label="Entre em contato pelo WhatsApp">
							<span class="final-contact-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24" role="img">
									<path
										d="M 20.52 3.48 A 11.92 11.92 0 0 0 12.04 0 C 5.42 0 0.04 5.38 0.04 12 C 0.04 14.12 0.6 16.19 1.65 18.01 L 0 24 L 6.15 22.39 A 11.99 11.99 0 0 0 12.04 24 C 18.66 24 24.04 18.62 24.04 12 A 11.92 11.92 0 0 0 20.52 3.48 Z M 12.04 21.88 A 9.9 9.9 0 0 1 7 20.5 L 6.64 20.29 L 2.99 21.24 L 3.97 17.68 L 3.73 17.31 A 9.86 9.86 0 1 1 12.04 21.88 Z"
									/>
									<path
										d="M 17.75 14.87 C 17.47 14.73 16.1 14.06 15.85 13.97 C 15.59 13.87 15.41 13.83 15.22 14.11 C 15.04 14.38 14.51 15.01 14.35 15.19 C 14.19 15.37 14.03 15.39 13.74 15.24 C 12.02 14.39 10.89 13.72 9.75 11.76 C 9.45 11.24 10.05 11.27 10.61 10.15 C 10.7 9.97 10.66 9.82 10.59 9.68 C 10.52 9.54 9.96 8.17 9.73 7.62 C 9.5 7.09 9.27 7.16 9.1 7.15 C 8.94 7.14 8.75 7.14 8.57 7.14 C 8.39 7.14 8.09 7.21 7.83 7.49 C 7.57 7.76 6.84 8.44 6.84 9.81 C 6.84 11.18 7.86 12.51 8 12.7 C 8.14 12.88 10 15.91 12.86 17.14 C 15.69 18.35 15.69 17.95 16.17 17.91 C 16.64 17.86 17.71 17.24 17.92 16.65 C 18.14 16.05 18.14 15.54 18.06 15.4 C 17.99 15.26 17.82 15.01 17.75 14.87 Z"
									/>
								</svg>
							</span>

							<span>ENTRE EM CONTATO</span>
						</a>
					</div>

					<div class="scroll-hint">
						<span>SCROLL</span>
						<div></div>
					</div>
				</div>
			</section>

		</main>

		<script>
			import gsap from "gsap";
			import { ScrollTrigger } from "gsap/ScrollTrigger";
			import Lenis from "lenis";

			gsap.registerPlugin(ScrollTrigger);

			const lenis = new Lenis({
				duration: 1.2,
				smoothWheel: true,
			});

			lenis.on("scroll", ScrollTrigger.update);

			gsap.ticker.add((time) => {
				lenis.raf(time * 1000);
			});

			gsap.ticker.lagSmoothing(0);

			const prefersReducedMotion = window.matchMedia(
				"(prefers-reduced-motion: reduce)",
			).matches;

			const introIdleTargets = [
				"#idle-home",
				"#idle-game",
				"#idle-data",
			];

			let introIdleActive = false;
			let introIdleTweens: gsap.core.Tween[] = [];

			gsap.set(introIdleTargets, {
				x: 0,
				y: 0,
				scale: 1,
				transformOrigin: "50% 50%",
			});

			const startIntroIdle = () => {
				if (prefersReducedMotion || introIdleActive) return;

				introIdleActive = true;

				introIdleTweens = [
					gsap.to("#idle-home", {
						x: 10,
						y: -9,
						scale: 1.02,
						duration: 1.8,
						repeat: -1,
						yoyo: true,
						ease: "sine.inOut",
					}),

					gsap.to("#idle-game", {
						x: -11,
						y: 8,
						scale: 1.018,
						duration: 1.6,
						repeat: -1,
						yoyo: true,
						ease: "sine.inOut",
					}),

					gsap.to("#idle-data", {
						x: 11,
						y: 11,
						scale: 1.02,
						duration: 1.9,
						repeat: -1,
						yoyo: true,
						ease: "sine.inOut",
					}),
				];
			};

			const stopIntroIdle = () => {
				if (!introIdleActive) return;

				introIdleActive = false;

				introIdleTweens.forEach((tween) => tween.kill());
				introIdleTweens = [];

				// Reset imediato para não desalinha os conectores
				// caso a pessoa role rapidamente.
				gsap.set(introIdleTargets, {
					x: 0,
					y: 0,
					scale: 1,
				});
			};

			const timeline = gsap.timeline({
				scrollTrigger: {
					trigger: ".scroll-stage",
					start: "top top",
					end: "bottom bottom",
					scrub: 1.2,
					invalidateOnRefresh: true,

					onUpdate: (self) => {
						if (self.progress <= 0.001) {
							startIntroIdle();
						} else {
							stopIntroIdle();
						}
					},
				},
			});

			gsap.set(".node-icon", {
				opacity: 0,
				scale: 0.5,
			});

			gsap.set(".copy:not(#start-copy)", {
				opacity: 0,
				y: 50,
			});

			gsap.set("#start-copy", {
				opacity: 1,
				y: 0,
			});

			gsap.set("#brand-scene", {
				opacity: 1,
				y: 0,
			});

			gsap.set(".brand-letter-n", {
				opacity: 0,
				x: -70,
			});

			gsap.set(".brand-letter-den", {
				opacity: 0,
				x: 70,
			});

			gsap.set(".brand-subtitle", {
				opacity: 0,
				y: 14,
			});

			gsap.set("#about-copy .about-marker > *", {
				opacity: 0,
				x: -18,
			});

			gsap.set("#about-copy .about-heading > *", {
				opacity: 0,
				y: 24,
			});

			gsap.set("#about-copy .service-card", {
				opacity: 0,
				y: 24,
			});

			gsap.set("#brand-symbol", {
				scale: 1,
				x: 0,
				y: 0,
				rotation: 0,
			});

			const connectorPaths = gsap.utils.toArray<SVGPathElement>(
				"#connector-layer .flow",
			);

			gsap.set("#connector-layer", {
				opacity: 1,
			});

			connectorPaths.forEach((path) => {
				const length = path.getTotalLength();

				gsap.set(path, {
					opacity: 0,
					strokeDasharray: length,
					strokeDashoffset: length,
				});
			});


			const placeIntroNode = (
				selector: string,
				targetX: number,
				targetY: number,
				scale: number,
				rotation: number,
			) => {
				const node = document.querySelector<SVGGElement>(selector);
				const ring = node?.querySelector<SVGGeometryElement>(".module-ring");

				if (!node || !ring) return;

				const bounds = ring.getBoundingClientRect();
				const currentX = bounds.left + bounds.width / 2;
				const currentY = bounds.top + bounds.height / 2;

				gsap.set(node, {
					x: targetX - currentX,
					y: targetY - currentY,
					scale,
					rotation,
				});
			};

			const placeIntroNodes = () => {
				const mobile = window.innerWidth <= 800;
				const nodeScale = mobile ? 0.4 : 0.68;
				const bottomY = window.innerHeight * (mobile ? 0.86 : 0.8);

				placeIntroNode(
					"#node-home",
					window.innerWidth * 0.5,
					window.innerHeight * (mobile ? 0.12 : 0.15),
					nodeScale,
					mobile ? -8 : -16,
				);

				placeIntroNode(
					"#node-game",
					window.innerWidth * (mobile ? 0.17 : 0.08),
					bottomY,
					nodeScale,
					mobile ? 8 : 14,
				);

				placeIntroNode(
					"#node-data",
					window.innerWidth * (mobile ? 0.83 : 0.92),
					bottomY,
					nodeScale,
					mobile ? -8 : -14,
				);
			};

			placeIntroNodes();
			startIntroIdle();

			const brandSymbol =
				document.querySelector<HTMLElement>("#brand-symbol");
			const brandSymbolSlot =
				document.querySelector<HTMLElement>("#brand-symbol-slot");

			const getBrandSymbolTarget = () => {
				if (!brandSymbol || !brandSymbolSlot) {
					return { x: 0, y: 0, scale: 0.25 };
				}

				const slotBounds = brandSymbolSlot.getBoundingClientRect();
				const symbolWidth = brandSymbol.offsetWidth || 1;

				return {
					x:
						slotBounds.left +
						slotBounds.width / 2 -
						window.innerWidth / 2,
					y:
						slotBounds.top +
						slotBounds.height / 2 -
						window.innerHeight / 2,
					scale: slotBounds.width / symbolWidth,
				};
			};

			const getDivisionSymbolState = () => {
				const mobile = window.innerWidth <= 800;

				return {
					x: mobile ? 0 : -205,
					y: mobile ? -window.innerHeight * 0.28 : 42,
					scale: mobile ? 0.78 : 1.42,
				};
			};

			const finalSymbolSlot =
				document.querySelector<HTMLElement>("#final-symbol-slot");

			const getFinalIntroSymbolState = () => {
				const mobile = window.innerWidth <= 800;

				return {
					x: 0,
					y: mobile ? -188 : -178,
					scale: mobile ? 0.19 : 0.22,
				};
			};

			const getFinalSymbolTarget = () => {
				if (!brandSymbol || !finalSymbolSlot) {
					return { x: 0, y: 0, scale: 0.28 };
				}

				const slotBounds = finalSymbolSlot.getBoundingClientRect();
				const symbolWidth = brandSymbol.offsetWidth || 1;

				return {
					x:
						slotBounds.left +
						slotBounds.width / 2 -
						window.innerWidth / 2,
					y:
						slotBounds.top +
						slotBounds.height / 2 -
						window.innerHeight / 2,
					scale: slotBounds.width / symbolWidth,
				};
			};

			gsap.set(".division-copy", {
				x: 24,
			});

			gsap.set("#final-copy", {
				opacity: 1,
				y: 0,
			});

			gsap.set(".final-demand-line", {
				opacity: 0,
				y: 34,
			});

			gsap.set(".final-brand-letter-n", {
				opacity: 0,
				x: -70,
			});

			gsap.set(".final-brand-letter-den", {
				opacity: 0,
				x: 70,
			});

			gsap.set(".final-contact-link", {
				opacity: 0,
				y: 22,
			});

			gsap.from("#site-header", {
				opacity: 0,
				y: -18,
				duration: 0.9,
				delay: 0.12,
				ease: "power2.out",
			});

			gsap.fromTo(
				"#start-copy .start-kicker",
				{ opacity: 0, y: 14 },
				{ opacity: 1, y: 0, duration: 0.8, delay: 0.1, ease: "power2.out" },
			);

			gsap.fromTo(
				"#start-copy h1",
				{ opacity: 0, y: 28 },
				{ opacity: 1, y: 0, duration: 1, delay: 0.2, ease: "power3.out" },
			);

			gsap.fromTo(
				"#start-copy .start-message",
				{ opacity: 0, y: 18 },
				{ opacity: 1, y: 0, duration: 0.9, delay: 0.38, ease: "power2.out" },
			);

			gsap.fromTo(
				".module-ring",
				{ opacity: 0 },
				{
					opacity: 1,
					duration: 1.1,
					delay: 0.2,
					stagger: 0.12,
					ease: "power2.out",
				},
			);

			timeline.to(
					"#start-copy",
					{
						opacity: 0,
						y: -35,
						scale: 0.96,
						duration: 1,
						ease: "power2.inOut",
					},
					0.45,
				)
				.to(
					"#node-home, #node-game, #node-data",
					{
						x: 0,
						y: 0,
						scale: 1,
						rotation: 0,
						duration: 2.25,
						ease: "power3.inOut",
					},
					0.35,
				)
				.to(
					connectorPaths,
					{
						opacity: 0.95,
						strokeDashoffset: 0,
						duration: 0.68,
						stagger: 0.08,
						ease: "power2.out",
					},
					2.6,
				)

				.to(
					".scroll-hint",
					{
						opacity: 0,
						y: 12,
						duration: 0.45,
						ease: "power2.out",
					},
					2.15,
				)
				.to(
					"#brand-symbol",
					{
						scale: 0.95,
						y: 0,
						duration: 2,
					},
					0.35,
				)

				.to(
					"#brand-symbol",
					{
						x: () => getBrandSymbolTarget().x,
						y: () => getBrandSymbolTarget().y,
						scale: () => getBrandSymbolTarget().scale,
						rotation: 0,
						duration: 1.3,
						ease: "power3.inOut",
					},
					3.15,
				)

				.to(
					".brand-letter-n",
					{
						opacity: 1,
						x: 0,
						duration: 0.8,
						ease: "power3.out",
					},
					3.58,
				)

				.to(
					".brand-letter-den",
					{
						opacity: 1,
						x: 0,
						duration: 0.8,
						ease: "power3.out",
					},
					3.58,
				)

				.to(
					".brand-subtitle",
					{
						opacity: 1,
						y: 0,
						duration: 0.65,
						ease: "power2.out",
					},
					4.02,
				)

				.to(
					"#about-copy .about-marker > *",
					{
						opacity: 1,
						x: 0,
						duration: 0.5,
						stagger: 0.07,
						ease: "power2.out",
					},
					4.35,
				)

				.to(
					"#about-copy .about-heading > *",
					{
						opacity: 1,
						y: 0,
						duration: 0.72,
