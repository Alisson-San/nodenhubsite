		top: 39%;
		left: 50%;
		display: grid;
		grid-template-columns: minmax(130px, 170px) minmax(0, 1fr);
		gap: clamp(38px, 4.5vw, 70px);
		align-items: start;
		width: min(90vw, 1160px);
		text-align: left;
		transform: translateX(-50%);
	}

	.about-marker {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		padding-top: 6px;
	}

	.about-index {
		color: rgba(112, 145, 190, 0.42);
		font-size: 0.6rem;
		font-weight: 500;
		letter-spacing: 0.24em;
	}

	.about-eyebrow {
		display: block;
		margin-top: 14px;
		color: #79aaf0;
		font-size: clamp(0.58rem, 0.66vw, 0.7rem);
		font-weight: 600;
		letter-spacing: 0.4em;
		white-space: nowrap;
	}

	.about-line {
		display: block;
		width: min(100%, 128px);
		height: 1px;
		margin-top: 20px;
		background: linear-gradient(
			90deg,
			rgba(167, 49, 255, 0.9),
			rgba(38, 134, 255, 0.85),
			transparent
		);
	}

	.about-content {
		min-width: 0;
	}

	.about-kicker {
		display: block;
		margin-bottom: 14px;
		color: #6e86a7;
		font-size: 0.6rem;
		font-weight: 600;
		letter-spacing: 0.32em;
	}

	.about-copy h2 {
		max-width: 820px;
		margin: 0;
		padding-bottom: 0.12em;
		overflow: visible;
		color: #f7f9ff;
		font-size: clamp(2.35rem, 3.35vw, 4rem);
		font-weight: 400;
		line-height: 1.08;
		letter-spacing: -0.052em;
	}

	.about-copy h2 span {
		color: #a9c7ff;
	}

	.about-lead {
		max-width: 760px;
		margin: 18px 0 0;
		color: #91a1b8;
		font-size: clamp(0.98rem, 1.05vw, 1.12rem);
		font-weight: 300;
		line-height: 1.65;
	}

	.about-coverage {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 12px 18px;
		margin-top: 18px;
	}

	.coverage-label {
		color: #7188a8;
		font-size: 0.55rem;
		font-weight: 600;
		letter-spacing: 0.24em;
		white-space: nowrap;
	}

	.coverage-cities {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.coverage-cities span {
		display: inline-flex;
		align-items: center;
		min-height: 28px;
		padding: 6px 10px;
		border: 1px solid rgba(94, 135, 197, 0.16);
		border-radius: 999px;
		background: rgba(17, 39, 70, 0.16);
		color: #a8b9d0;
		font-size: 0.68rem;
		font-weight: 400;
		letter-spacing: 0.04em;
	}

	.about-services {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		margin-top: 28px;
	}

	.service-card {
		position: relative;
		min-height: 152px;
		padding: 20px 20px 18px;
		overflow: hidden;
		border: 1px solid rgba(104, 139, 192, 0.15);
		border-radius: 16px;
		background:
			linear-gradient(180deg, rgba(19, 37, 64, 0.32), rgba(8, 15, 27, 0.18));
	}

	.service-card::before {
		position: absolute;
		top: 0;
		right: 0;
		left: 0;
		height: 2px;
		content: "";
	}

	.service-home::before {
		background: linear-gradient(90deg, #463bff, #19d4ef);
	}

	.service-game::before {
		background: linear-gradient(90deg, #c52aff, #523aff);
	}

	.service-data::before {
		background: linear-gradient(90deg, #2858ff, #17d9ef);
	}

	.service-number {
		color: rgba(128, 153, 190, 0.5);
		font-size: 0.55rem;
		font-weight: 600;
		letter-spacing: 0.2em;
	}

	.service-card h3 {
		margin: 17px 0 10px;
		color: #f4f7fc;
		font-size: clamp(1rem, 1.2vw, 1.25rem);
		font-weight: 500;
		letter-spacing: -0.025em;
	}

	.service-card p {
		margin: 0;
		color: #7f90a7;
		font-size: clamp(0.76rem, 0.82vw, 0.88rem);
		font-weight: 300;
		line-height: 1.55;
	}

	.copy span {
		letter-spacing: 0.5em;
		font-size: 0.7rem;
		color: #7894b8;
	}

	.copy {
		position: absolute;
		z-index: 10;
	}

	.copy h1,
	.copy h2 {
		font-size: clamp(2.7rem, 5vw, 6rem);
		line-height: 0.98;
		font-weight: 400;
		letter-spacing: -0.05em;
		margin: 25px 0;
	}
	
	.division-shell {
		position: absolute;
		top: 0;
		right: clamp(44px, 5.4vw, 88px);
		bottom: 0;
		z-index: 10;

		display: flex;
		align-items: center;

		width: clamp(370px, 30vw, 500px);
		pointer-events: none;
	}

	.division-shell > .division-copy {
		position: relative;
		top: auto;
		right: auto;
		bottom: auto;
		left: auto;

		width: 100%;
		pointer-events: auto;
	}
	.division-copy {
		--division-glow: linear-gradient(90deg, #3e49ff, #18d5ee);

		position: relative;
		width: 100%;
		padding: 30px 32px 28px;
		overflow: hidden;

		border: 1px solid rgba(116, 150, 202, 0.14);
		border-radius: 24px;

		background:
			linear-gradient(
				180deg,
				rgba(12, 25, 45, 0.76),
				rgba(6, 11, 20, 0.42)
			);

		backdrop-filter: blur(16px);
		box-shadow: 0 26px 60px rgba(0, 0, 0, 0.18);
	}

	.division-copy::before {
		position: absolute;
		top: -28px;
		left: 32px;
		right: 32px;
		height: 76px;
		background: var(--division-glow);
		border-radius: 999px;
		filter: blur(26px);
		opacity: 0.35;
		content: "";
	}

	.division-copy::after {
		position: absolute;
		top: 0;
		right: 0;
		left: 0;
		height: 1px;
		background: var(--division-glow);
		opacity: 0.95;
		content: "";
	}

	.division-home {
		--division-glow: linear-gradient(90deg, #3e49ff, #18d5ee);
	}

	.division-game {
		--division-glow: linear-gradient(90deg, #c32aff, #5f4cff);
	}

	.division-data {
		--division-glow: linear-gradient(90deg, #2a5aff, #18d8ef);
	}

	.division-copy .division-kicker {
		display: inline-block;
		margin-bottom: 18px;
		color: #77a6e7;
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.34em;
	}

	.division-copy h2 {
		margin: 0;
		font-size: clamp(1.86rem, 2.85vw, 3.45rem);
		line-height: 1.04;
		letter-spacing: -0.052em;
	}

	.division-copy .division-lead {
		margin: 18px 0 0;
		color: #9aa8bc;
		font-size: clamp(0.95rem, 0.96vw, 1.04rem);
		font-weight: 300;
		line-height: 1.62;
		letter-spacing: 0;
	}

	.division-list {
		display: grid;
		gap: 10px;
		margin: 22px 0 0;
		padding: 0;
		list-style: none;
	}

	.division-list li {
		position: relative;
		padding-left: 20px;
		color: #d4dded;
		font-size: clamp(0.86rem, 0.9vw, 0.94rem);
		font-weight: 300;
		line-height: 1.5;
	}

	.division-list li::before {
		position: absolute;
		left: 0;
		top: 0.58em;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: linear-gradient(135deg, #bd38ff, #29a5ff);
		content: "";
	}

	.division-copy .division-meta {
		margin: 22px 0 0;
		color: #7487a3;
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.26em;
		text-transform: uppercase;
	}

	.final-copy {
		left: 50%;
		top: 52%;
		width: min(92vw, 1050px);
		text-align: center;
		transform: translate(-50%, -50%);
	}

	.final-demand {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 100%;
		transform: translate(-50%, -50%);
	}

	.final-demand h2 {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		margin: 0;
		font-size: clamp(3.2rem, 6.5vw, 7rem);
		font-weight: 400;
		line-height: 0.96;
		letter-spacing: -0.06em;
	}

	.final-copy .final-demand-line {
		display: block;
		font-size: inherit;
		line-height: inherit;
		letter-spacing: inherit;
		color: inherit;
	}

	.final-demand-line-two {
		background: linear-gradient(92deg, #ffffff 0%, #a9c8ff 55%, #8e72ff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.final-brand-lockup {
		position: absolute;
		left: 50%;
		top: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: clamp(7px, 0.85vw, 13px);
		width: 100%;
		color: #f7f9ff;
		font-size: clamp(4.8rem, 8.4vw, 9.2rem);
		font-weight: 500;
		line-height: 0.86;
		letter-spacing: 0.085em;
		text-transform: uppercase;
		transform: translate(-50%, -50%);
	}

	.final-copy .final-brand-letter {
		display: inline-block;
		font-size: inherit;
		line-height: inherit;
		letter-spacing: inherit;
		color: inherit;
	}

	.final-brand-letter-den {
		margin-right: -0.11em;
	}

	.final-symbol-slot {
		display: block;
		flex: 0 0 auto;
		width: clamp(92px, 7.35vw, 132px);
		aspect-ratio: 1;
	}

	.final-contact-link {
		position: absolute;
		left: 50%;
		top: calc(50% + clamp(100px, 9vw, 150px));
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		padding: 17px 26px;
		color: #ffffff;
		text-decoration: none;
		border: 1px solid rgba(255, 255, 255, 0.24);
		border-radius: 999px;
		background: rgba(11, 19, 33, 0.3);
		letter-spacing: 0.18em;
		font-size: 0.68rem;
		font-weight: 600;
		transform: translateX(-50%);
		transition:
			border-color 220ms ease,
			background-color 220ms ease,
			box-shadow 220ms ease;
	}

	.final-contact-link:hover {
		border-color: rgba(66, 148, 255, 0.56);
		background: rgba(24, 50, 88, 0.4);
		box-shadow: 0 0 28px rgba(43, 121, 255, 0.14);
	}

	.final-contact-icon {
		display: inline-flex;
		width: 18px;
		height: 18px;
		color: #ffffff;
	}

	.final-contact-icon svg {
		width: 100%;
		height: 100%;
		fill: currentColor;
	}

	.final-copy .final-contact-link > span:last-child {
		color: inherit;
		font-size: inherit;
		line-height: 1;
		letter-spacing: inherit;
	}

	.scroll-hint {
		position: absolute;
		bottom: 30px;
		left: 50%;
		transform: translateX(-50%);
		text-align: center;
		color: #53657c;
		font-size: 0.55rem;
		letter-spacing: 0.4em;
	}

	.scroll-hint div {
		width: 1px;
		height: 40px;
		background: linear-gradient(#53657c, transparent);
		margin: 10px auto;
	}


	@media (max-width: 800px) {
		html,
		body {
			width: 100%;
			overflow-x: hidden;
		}

		.scroll-stage {
			height: 1550svh;
		}

		.scene {
			height: 100svh;
			min-height: 100svh;
		}

		.site-header,
		.site-header.is-scrolled {
			height: 60px;
			padding: 0 16px;
		}

		.site-logo {
			gap: 4px;
			font-size: 0.82rem;
			letter-spacing: 0.16em;
		}

		.site-logo-mark {
			width: 27px;
			height: 27px;
			margin: 0;
		}

		.menu-toggle {
			display: block;
			width: 38px;
			height: 38px;
		}

		.menu-toggle span {
			left: 10px;
		}

		.site-navigation {
			position: fixed;
			inset: 0;
			z-index: 101;
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			justify-content: center;
			gap: 8px;
			padding: 82px 24px 32px;
			background:
				radial-gradient(circle at 75% 18%, rgba(25, 123, 226, 0.16), transparent 30%),
				radial-gradient(circle at 20% 80%, rgba(143, 38, 255, 0.13), transparent 30%),
				rgba(2, 5, 10, 0.97);
			backdrop-filter: blur(22px);
			opacity: 0;
			pointer-events: none;
			transform: translateY(-14px);
			transition:
				opacity 240ms ease,
				transform 240ms ease;
		}

		.site-header.is-menu-open .site-navigation {
			opacity: 1;
			pointer-events: auto;
			transform: translateY(0);
		}

		.site-navigation a {
			width: 100%;
			padding: 12px 0;
			font-size: clamp(1.25rem, 6.8vw, 2rem);
			font-weight: 400;
			letter-spacing: -0.025em;
			text-transform: none;
		}

		.site-navigation a::after {
			right: auto;
			bottom: 6px;
			width: 52px;
		}

		.site-navigation .navigation-contact {
			width: auto;
			margin-top: 12px;
			padding: 12px 20px;
			font-size: 0.72rem;
			letter-spacing: 0.13em;
			text-transform: uppercase;
		}

		.noden-symbol {
			width: min(78vw, 320px);
			max-width: 320px;
		}

		.copy.start-copy {
			top: 48%;
			width: 88vw;
		}

		.copy.start-copy .start-kicker {
			margin-bottom: 12px;
			font-size: 0.5rem;
			letter-spacing: 0.3em;
		}

		.copy.start-copy h1 {
			font-size: clamp(3rem, 16vw, 4.8rem);
			line-height: 0.9;
		}

		.copy.start-copy .start-message {
			gap: 5px;
			margin-top: 18px;
			font-size: clamp(0.95rem, 4.3vw, 1.18rem);
		}

		.copy.start-copy .start-message span {
			font-size: 0.72rem;
			letter-spacing: 0.22em;
		}

		.scroll-hint {
			bottom: 12px;
		}

		.scroll-hint div {
			height: 24px;
		}

		/* Marca + quem somos */
		.brand-lockup {
			top: 8.5%;
			width: 94vw;
		}

		.brand-word {
			gap: 4px;
			font-size: clamp(2.6rem, 12vw, 4rem);
			letter-spacing: 0.055em;
		}

		.brand-symbol-slot {
			width: clamp(52px, 14vw, 72px);
		}

		.brand-subtitle {
			margin-top: 10px;
			font-size: 0.45rem;
			letter-spacing: 0.3em;
		}

		.about-copy {
			top: 25%;
			display: block;
			width: 90vw;
		}

		.about-marker {
			display: grid;
			grid-template-columns: auto auto 1fr;
			gap: 9px;
			align-items: center;
			padding: 0;
		}

		.about-index,
		.about-eyebrow {
			margin: 0;
			font-size: 0.46rem;
		}

		.about-line {
			width: 100%;
			margin: 0;
		}

		.about-content {
			margin-top: 14px;
		}

		.about-kicker {
			margin-bottom: 8px;
			font-size: 0.46rem;
			letter-spacing: 0.2em;
		}

		.about-copy h2 {
			padding-bottom: 0.08em;
			font-size: clamp(1.65rem, 7.6vw, 2.35rem);
			line-height: 1.04;
		}

		.about-lead {
			margin-top: 10px;
			font-size: 0.78rem;
			line-height: 1.45;
		}

		.about-coverage {
			display: block;
			margin-top: 10px;
		}

		.coverage-label {
			display: block;
			margin-bottom: 6px;
			font-size: 0.43rem;
			letter-spacing: 0.16em;
		}

		.coverage-cities {
			gap: 5px;
		}

		.coverage-cities span {
			min-height: 22px;
			padding: 4px 7px;
			font-size: 0.54rem;
		}

		.about-services {
			grid-template-columns: 1fr;
			gap: 6px;
			margin-top: 12px;
		}

		.service-card {
			display: grid;
			grid-template-columns: auto 1fr;
			align-items: center;
			gap: 9px;
			min-height: 0;
			padding: 10px 12px;
			border-radius: 11px;
		}

		.service-number {
			font-size: 0.48rem;
		}

		.service-card h3 {
			margin: 0;
			font-size: 0.82rem;
		}

		.service-card p {
			display: none;
		}

		/* Fallback caso a página desktop seja aberta em uma tela pequena. */
		.division-shell {
			top: 0;
			right: 5vw;
			bottom: 0;
			left: 5vw;
			width: auto;
		}

		.division-shell > .division-copy {
			top: auto;
			right: auto;
			bottom: auto;
			left: auto;
			width: 100%;
			padding: 17px 16px 15px;
			border-radius: 17px;
			backdrop-filter: blur(12px);
		}

		.division-copy::before {
			top: -18px;
			left: 18px;
			right: 18px;
			height: 48px;
			filter: blur(20px);
			opacity: 0.28;
		}

		.division-copy .division-kicker {
			margin-bottom: 9px;
			font-size: 0.49rem;
			letter-spacing: 0.23em;
		}

		.division-copy h2 {
			font-size: clamp(1.45rem, 7vw, 2rem);
			line-height: 1.02;
		}

		.division-copy .division-lead {
			margin-top: 9px;
			font-size: 0.78rem;
			line-height: 1.4;
		}

		.division-list {
			gap: 5px;
			margin-top: 11px;
		}

		.division-list li {
			padding-left: 15px;
			font-size: 0.7rem;
			line-height: 1.32;
		}

		.division-list li::before {
			top: 0.48em;
			width: 6px;
			height: 6px;
		}

		.division-copy .division-meta {
			margin-top: 10px;
			font-size: 0.43rem;
			line-height: 1.35;
			letter-spacing: 0.13em;
		}

		/* Encerramento */
		.final-copy {
			top: 51%;
			left: 50%;
			right: auto;
			width: 94vw;
			transform: translate(-50%, -50%);
		}

		.final-demand h2 {
			gap: 4px;
			font-size: clamp(2.4rem, 12.5vw, 3.8rem);
		}

		.final-brand-lockup {
			gap: 3px;
			font-size: clamp(2.8rem, 14vw, 4.7rem);
			letter-spacing: 0.045em;
		}

		.final-symbol-slot {
			width: clamp(54px, 15vw, 74px);
		}

		.final-contact-link {
			top: calc(50% + 82px);
			width: min(86vw, 320px);
			padding: 14px 17px;
			font-size: 0.58rem;
			letter-spacing: 0.11em;
		}
	}

	@media (max-width: 800px) and (max-height: 720px) {
		.about-copy {
			top: 22%;
		}

		.about-lead {
			font-size: 0.72rem;
		}

		.coverage-cities span {
			padding: 3px 6px;
		}

		.service-card {
			padding: 8px 10px;
		}

		.division-copy,
		.intro-copy {
			top: 67%;
		}

		.division-copy {
			padding: 14px 15px 13px;
		}

		.division-copy h2 {
			font-size: 1.35rem;
		}

		.division-copy .division-lead {
			font-size: 0.72rem;
		}

		.division-list li {
			font-size: 0.64rem;
		}

		.division-copy .division-meta {
			display: none;
		}
	}

	@media (max-width: 800px) and (orientation: landscape) {
		.noden-symbol {
			width: min(42vw, 250px);
		}

		.about-copy {
			top: 20%;
			width: 92vw;
		}

		.about-services {
			grid-template-columns: repeat(3, 1fr);
		}

		.service-card {
			display: block;
			padding: 8px;
			text-align: center;
		}

		.division-copy,
		.intro-copy {
			left: auto;
			right: 4vw;
			top: 54%;
