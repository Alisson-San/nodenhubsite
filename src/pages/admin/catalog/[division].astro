---
export const prerender = false;

import type {
	Json,
} from "../../../types/database.types";

import AdminLayout
	from "../../../layouts/AdminLayout.astro";

import {
	createSupabaseRequestClient,
} from "../../../lib/supabase/request";

import {
	divisionLabels,
	isServiceDivision,
} from "../../../lib/admin/divisions";

const requestedDivision =
	Astro.params.division;

if (
	!isServiceDivision(
		requestedDivision,
	)
) {
	return Astro.redirect(
		"/admin/catalog?error=division",
		303,
	);
}

const division =
	requestedDivision;

const supabase =
	createSupabaseRequestClient({
		request: Astro.request,
		cookies: Astro.cookies,
	});

const {
	data: page,
	error: pageError,
} = await supabase
	.from("service_pages")
	.select(`
		id,
		division,
		hero_title
	`)
	.eq("division", division)
	.single();

if (
	pageError ||
	!page
) {
	console.error(
		"[Noden Admin] Falha ao carregar divisão.",
		pageError,
	);

	return Astro.redirect(
		"/admin/catalog?error=load",
		303,
	);
}

const {
	data,
	error: servicesError,
} = await supabase
	.from("services")
	.select("*")
	.eq(
		"service_page_id",
		page.id,
	)
	.order(
		"sort_order",
		{
			ascending: true,
		},
	)
	.order(
		"created_at",
		{
			ascending: true,
		},
	);

if (servicesError) {
	console.error(
		"[Noden Admin] Falha ao carregar serviços.",
		servicesError,
	);
}

const services =
	data ?? [];

const nextSortOrder =
	services.length === 0
		? 0
		: Math.max(
				...services.map(
					(service) =>
						service.sort_order,
				),
			) + 10;

function jsonArrayToLines(
	value: Json,
): string {
	if (!Array.isArray(value)) {
		return "";
	}

	return value
		.filter(
			(item): item is string =>
				typeof item === "string",
		)
		.join("\n");
}

const saved =
	Astro.url.searchParams.get("saved");

const errorCode =
	Astro.url.searchParams.get("error");

const savedMessages:
	Record<string, string> = {
	created:
		"Serviço criado com sucesso.",

	updated:
		"Serviço atualizado com sucesso.",
};

const errorMessages:
	Record<string, string> = {
	validation:
		"Revise os campos obrigatórios.",

	origin:
		"A origem da solicitação não foi aceita.",

	"not-found":
		"O serviço informado não foi encontrado.",

	save:
		"Não foi possível salvar o serviço.",
};
---

<AdminLayout
	title={`${divisionLabels[division]} — Catálogo`}
	description="Crie, organize e ative os serviços exibidos nesta divisão."
>
	<Fragment slot="actions">
		<a
			class="preview"
			href={`/${division}#servicos`}
			target="_blank"
			rel="noreferrer"
		>
			Visualizar serviços ↗
		</a>
	</Fragment>

	<nav
		class="catalog-tabs"
		aria-label="Áreas do catálogo"
	>
		<a
			class="active"
			href={`/admin/catalog/${division}`}
		>
			Serviços
		</a>

		<span>
			Preços — próxima etapa
		</span>
	</nav>

	{
		saved && savedMessages[saved] && (
			<p
				class="message success"
				role="status"
			>
				{savedMessages[saved]}
			</p>
		)
	}

	{
		errorCode && (
			<p
				class="message error"
				role="alert"
			>
				{
					errorMessages[errorCode] ??
						"Não foi possível concluir a operação."
				}
			</p>
		)
	}

	<section class="editor new-service">
		<header class="editor__header">
			<div>
				<span>Novo serviço</span>
				<h2>Adicionar ao catálogo</h2>
			</div>
		</header>

		<form
			method="post"
			action={`/api/admin/catalog/${division}/services`}
		>
			<div class="fields">
				<label class="full">
					<span>Título</span>

					<input
						type="text"
						name="title"
						required
					/>
				</label>

				<label class="full">
					<span>Descrição</span>

					<textarea
						name="description"
						rows="4"
						required
					></textarea>
				</label>

				<label class="full">
					<span>
						Recursos — um por linha
					</span>

					<textarea
						name="features"
						rows="5"
					></textarea>
				</label>

				<label>
					<span>Selo opcional</span>

					<input
						type="text"
						name="badge"
						placeholder="Mais procurado"
					/>
				</label>

				<label>
					<span>Ordem</span>

					<input
						type="number"
						name="sort_order"
						min="0"
						step="1"
						value={nextSortOrder}
						required
					/>
				</label>

				<label class="checkbox full">
					<input
						type="checkbox"
						name="is_active"
						value="true"
						checked
					/>

					<span>Serviço ativo no site</span>
				</label>
			</div>

			<footer class="form-footer">
				<button type="submit">
					Criar serviço
				</button>
			</footer>
		</form>
	</section>

	<section
		id="services"
		class="service-list"
	>
		<header class="section-heading">
			<div>
				<p>Serviços cadastrados</p>

				<h2>
					{services.length} itens
				</h2>
			</div>
		</header>

		{
			services.length === 0 ? (
				<p class="empty">
					Nenhum serviço cadastrado
					nesta divisão.
				</p>
			) : (
				services.map((service) => (
					<details
						class:list={[
							"service-card",
							{
								inactive:
									!service.is_active,
							},
						]}
					>
						<summary>
							<div>
								<strong>
									{service.title}
								</strong>

								<small>
									Ordem {service.sort_order}
								</small>
							</div>

							<span
								class:list={[
									"status",
									{
										active:
											service.is_active,
									},
								]}
							>
								{
									service.is_active
										? "Ativo"
										: "Inativo"
								}
							</span>
						</summary>

						<form
							method="post"
							action={`/api/admin/catalog/${division}/services`}
						>
							<input
								type="hidden"
								name="service_id"
								value={service.id}
							/>

							<div class="fields">
								<label class="full">
									<span>Título</span>

									<input
										type="text"
										name="title"
										value={service.title}
										required
									/>
								</label>

								<label class="full">
									<span>Descrição</span>

									<textarea
										name="description"
										rows="4"
										required
									>{service.description}</textarea>
								</label>

								<label class="full">
									<span>
										Recursos — um por linha
									</span>

									<textarea
										name="features"
										rows="5"
									>{jsonArrayToLines(
										service.features,
									)}</textarea>
								</label>

								<label>
									<span>
										Selo opcional
									</span>

									<input
										type="text"
										name="badge"
										value={
											service.badge ??
												""
										}
									/>
								</label>

								<label>
									<span>Ordem</span>

									<input
										type="number"
										name="sort_order"
										min="0"
										step="1"
										value={
											service.sort_order
										}
										required
									/>
								</label>

								<label class="checkbox full">
									<input
										type="checkbox"
										name="is_active"
										value="true"
										checked={
											service.is_active
										}
									/>

									<span>
										Serviço ativo
										no site
									</span>
								</label>
							</div>

							<footer class="form-footer">
								<button type="submit">
									Salvar serviço
								</button>
							</footer>
						</form>
					</details>
				))
			)
		}
	</section>
</AdminLayout>

<style>
	.preview {
		display: inline-flex;
		padding: 11px 15px;
		border: 1px solid
			rgba(105, 145, 205, 0.3);
		border-radius: 10px;
		background: rgba(41, 101, 190, 0.12);
		color: #b9d4fa;
		font-size: 0.72rem;
		text-decoration: none;
	}

	.catalog-tabs {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 26px;
		padding: 5px;
		border: 1px solid
			rgba(105, 145, 205, 0.18);
		border-radius: 12px;
		background: rgba(5, 13, 25, 0.78);
	}

	.catalog-tabs a,
	.catalog-tabs span {
		padding: 10px 14px;
		border-radius: 8px;
		color: #71849d;
		font-size: 0.72rem;
		text-decoration: none;
	}

	.catalog-tabs .active {
		background: rgba(46, 113, 211, 0.18);
		color: #d6e6ff;
	}

	.message {
		margin: 0 0 20px;
		padding: 15px 17px;
		border-radius: 11px;
		font-size: 0.78rem;
	}

	.success {
		border: 1px solid
			rgba(75, 220, 145, 0.25);
		background: rgba(35, 150, 100, 0.12);
		color: #8be2b6;
	}

	.error {
		border: 1px solid
			rgba(255, 100, 100, 0.25);
		background: rgba(160, 30, 40, 0.13);
		color: #ffb1b6;
	}

	.editor,
	.service-card {
		border: 1px solid
			rgba(105, 145, 205, 0.2);
		border-radius: 18px;
		background: rgba(7, 17, 31, 0.82);
	}

	.editor {
		padding: 28px;
	}

	.new-service {
		margin-bottom: 46px;
	}

	.editor__header {
		margin-bottom: 26px;
	}

	.editor__header span,
	.section-heading p {
		margin: 0;
		color: #619fea;
		letter-spacing: 0.14em;
		font-size: 0.61rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.editor__header h2,
	.section-heading h2 {
		margin: 7px 0 0;
		font-size: 1.25rem;
		font-weight: 500;
	}

	.fields {
		display: grid;
		grid-template-columns:
			repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	label {
		display: grid;
		gap: 8px;
	}

	label > span {
		color: #99abc1;
		font-size: 0.7rem;
		font-weight: 600;
	}

	.full {
		grid-column: 1 / -1;
	}

	input[type="text"],
	input[type="number"],
	textarea {
		width: 100%;
		padding: 13px 14px;
		border: 1px solid
			rgba(105, 145, 205, 0.28);
		border-radius: 10px;
		outline: none;
		background: rgba(2, 8, 16, 0.72);
		color: #f7faff;
		font: inherit;
		line-height: 1.5;
	}

	input:focus,
	textarea:focus {
		border-color: #428eff;
		box-shadow:
			0 0 0 3px
			rgba(48, 132, 255, 0.12);
	}

	.checkbox {
		display: flex;
		align-items: center;
		gap: 9px;
	}

	.checkbox input {
		width: 18px;
		height: 18px;
		accent-color: #347dff;
	}

	.form-footer {
		display: flex;
		justify-content: flex-end;
		margin-top: 22px;
	}

	.form-footer button {
		padding: 13px 20px;
		border: 1px solid
			rgba(80, 151, 255, 0.58);
		border-radius: 10px;
		cursor: pointer;
		background:
			linear-gradient(
				135deg,
				#245fc7,
				#347dff
			);
		color: white;
		font-weight: 700;
	}

	.service-list {
		display: grid;
		gap: 14px;
	}

	.section-heading {
		margin-bottom: 8px;
	}

	.service-card {
		overflow: hidden;
	}

	.service-card.inactive {
		opacity: 0.72;
	}

	.service-card summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		padding: 21px 24px;
		cursor: pointer;
		list-style: none;
	}

	.service-card summary::-webkit-details-marker {
		display: none;
	}

	.service-card summary div {
		display: grid;
		gap: 5px;
	}

	.service-card summary strong {
		font-size: 0.95rem;
	}

	.service-card summary small {
		color: #71849d;
		font-size: 0.65rem;
	}

	.service-card form {
		padding: 24px;
		border-top: 1px solid
			rgba(105, 145, 205, 0.16);
	}

	.status {
		padding: 5px 8px;
		border: 1px solid
			rgba(255, 180, 75, 0.25);
		border-radius: 99px;
		color: #ffc474;
		font-size: 0.58rem;
	}

	.status.active {
		border-color:
			rgba(80, 220, 155, 0.25);
		color: #75e2ae;
	}

	.empty {
		padding: 28px;
		border: 1px dashed
			rgba(105, 145, 205, 0.25);
		border-radius: 14px;
		color: #8193aa;
		text-align: center;
	}

	@media (max-width: 700px) {
		.fields {
			grid-template-columns: 1fr;
		}

		.full {
			grid-column: auto;
		}

		.editor {
			padding: 22px 18px;
		}

		.catalog-tabs {
			align-items: stretch;
			flex-direction: column;
		}
	}
</style>