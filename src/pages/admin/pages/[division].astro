---
export const prerender = false;

import type {
	Json,
} from "../../../types/database.types";

import AdminLayout
	from "../../../layouts/AdminLayout.astro";

import AdminColorField
	from "../../../components/admin/AdminColorField.astro";

import {
	createSupabaseRequestClient,
} from "../../../lib/supabase/request";

import {
	divisionLabels,
	isServiceDivision,
} from "../../../lib/admin/divisions";

const requestedDivision =
	Astro.params.division;

if (
	!isServiceDivision(
		requestedDivision,
	)
) {
	return Astro.redirect(
		"/admin/pages?error=division",
		303,
	);
}

const division =
	requestedDivision;

const supabase =
	createSupabaseRequestClient({
		request: Astro.request,
		cookies: Astro.cookies,
	});

const {
	data: page,
	error,
} = await supabase
	.from("service_pages")
	.select("*")
	.eq("division", division)
	.single();

if (
	error ||
	!page
) {
	console.error(
		"[Noden Admin] Falha ao carregar página.",
		error,
	);

	return Astro.redirect(
		"/admin/pages?error=load",
		303,
	);
}

function jsonArrayToLines(
	value: Json,
): string {
	if (!Array.isArray(value)) {
		return "";
	}

	return value
		.filter(
			(item): item is string =>
				typeof item === "string",
		)
		.join("\n");
}

const saved =
	Astro.url.searchParams.get("saved") ===
	"1";

const errorCode =
	Astro.url.searchParams.get("error");

const errorMessages:
	Record<string, string> = {
	validation:
		"Revise os campos obrigatórios, cores e links informados.",

	origin:
		"A origem da solicitação não foi aceita.",

	duplicate:
		"O caminho canônico já está sendo usado por outra página.",

	save:
		"Não foi possível salvar as alterações.",
};
---

<AdminLayout
	title={divisionLabels[division]}
	description="Edite todo o conteúdo, tema e chamadas exibidos na página pública."
>
	<Fragment slot="actions">
		<a
			class="preview"
			href={`/${division}`}
			target="_blank"
			rel="noreferrer"
		>
			Visualizar página ↗
		</a>
	</Fragment>

	{
		saved && (
			<p
				class="message success"
				role="status"
			>
				Alterações salvas com sucesso.
			</p>
		)
	}

	{
		errorCode && (
			<p
				class="message error"
				role="alert"
			>
				{
					errorMessages[errorCode] ??
						"Não foi possível concluir a operação."
				}
			</p>
		)
	}

	<form
		method="post"
		action={`/api/admin/pages/${division}`}
	>
		<section class="panel">
			<header>
				<div>
					<span>Publicação</span>
					<h2>Status da página</h2>
					<p>
						Controle a disponibilidade pública sem apagar o conteúdo.
					</p>
				</div>

				<label class="toggle">
					<input
						type="checkbox"
						name="is_published"
						value="true"
						checked={page.is_published}
					/>

					<span>Publicada</span>
				</label>
			</header>
		</section>

		<section class="panel">
			<header>
				<div>
					<span>SEO e endereço</span>
					<h2>Mecanismos de busca</h2>
					<p>
						Informações utilizadas no título do navegador, resultados de busca e URL canônica.
					</p>
				</div>
			</header>

			<div class="fields">
				<label class="full">
					<span>Título SEO</span>

					<input
						type="text"
						name="seo_title"
						value={page.seo_title}
						maxlength="100"
						required
					/>

					<small>
						Procure manter o serviço, a localidade e a marca em uma frase natural.
					</small>
				</label>

				<label class="full">
					<span>Descrição SEO</span>

					<textarea
						name="seo_description"
						rows="4"
						maxlength="320"
						required
					>{page.seo_description}</textarea>

					<small>
						Resumo curto da página para buscadores e compartilhamentos.
					</small>
				</label>

				<label class="full">
					<span>Caminho canônico</span>

					<input
						type="text"
						name="canonical_path"
						value={page.canonical_path}
						pattern="^\/(?:[a-zA-Z0-9]+(?:-[a-zA-Z0-9]+)*\/?)*$"
						placeholder="/home"
						autocomplete="off"
						required
					/>

					<small>
						Use somente um caminho interno iniciado por barra, como /home. Alterar esse campo muda a referência canônica, não a rota física do Astro.
					</small>
				</label>
			</div>
		</section>

		<section class="panel">
			<header>
				<div>
					<span>Tema</span>
					<h2>Cores da divisão</h2>
					<p>
						As duas cores alimentam gradientes, detalhes, botões e destaques da página.
					</p>
				</div>
			</header>

			<div class="fields">
				<AdminColorField
					name="accent_color"
					label="Cor principal"
					value={page.accent_color}
					role="page-primary"
					help="Digite o hexadecimal ou use o seletor visual."
				/>

				<AdminColorField
					name="accent_secondary_color"
					label="Cor secundária"
					value={page.accent_secondary_color}
					role="page-secondary"
					help="Utilizada em gradientes e elementos complementares."
				/>
			</div>
		</section>

		<section class="panel">
			<header>
				<div>
					<span>Hero</span>
					<h2>Apresentação principal</h2>
					<p>
						Primeira mensagem vista pelo cliente ao entrar na divisão.
					</p>
				</div>
			</header>

			<div class="fields">
				<label>
					<span>Texto superior</span>

					<input
						type="text"
						name="hero_eyebrow"
						value={page.hero_eyebrow}
						maxlength="100"
						required
					/>
				</label>

				<label class="full">
					<span>Título principal</span>

					<input
						type="text"
						name="hero_title"
						value={page.hero_title}
						maxlength="180"
						required
					/>
				</label>

				<label class="full">
					<span>Descrição</span>

					<textarea
						name="hero_description"
						rows="5"
						maxlength="800"
						required
					>{page.hero_description}</textarea>
				</label>

				<label class="full">
					<span>
						Destaques — um por linha
					</span>

					<textarea
						name="hero_highlights"
						rows="6"
						maxlength="800"
					>{jsonArrayToLines(
						page.hero_highlights,
					)}</textarea>
				</label>
			</div>
		</section>

		<section class="panel">
			<header>
				<div>
					<span>Ações do Hero</span>
					<h2>Botões e WhatsApp</h2>
					<p>
						O botão principal abre o WhatsApp. O secundário pode apontar para uma seção, página interna ou URL externa.
					</p>
				</div>
			</header>

			<div class="fields">
				<label>
					<span>Texto do botão principal</span>

					<input
						type="text"
						name="hero_primary_label"
						value={page.hero_primary_label ?? ""}
						maxlength="80"
						placeholder="Falar com a Noden"
					/>
				</label>

				<label class="full">
					<span>Mensagem do WhatsApp</span>

					<textarea
						name="hero_primary_message"
						rows="4"
						maxlength="1200"
						required
					>{page.hero_primary_message}</textarea>

					<small>
						Essa mensagem será preenchida automaticamente ao abrir o WhatsApp.
					</small>
				</label>

				<label>
					<span>Texto do botão secundário</span>

					<input
						type="text"
						name="hero_secondary_label"
						value={page.hero_secondary_label ?? ""}
						maxlength="80"
						placeholder="Ver serviços e preços"
					/>
				</label>

				<label>
					<span>Destino do botão secundário</span>

					<input
						type="text"
						name="hero_secondary_href"
						value={page.hero_secondary_href ?? ""}
						maxlength="500"
						placeholder="#precos"
					/>

					<small>
						Exemplos: #precos, /links ou https://exemplo.com.
					</small>
				</label>
			</div>
		</section>

		<section class="panel">
			<header>
				<div>
					<span>Serviços</span>
					<h2>Introdução dos cards institucionais</h2>
					<p>
						Os cards são gerenciados no Catálogo; estes campos controlam o cabeçalho da seção.
					</p>
				</div>
			</header>

			<div class="fields">
				<label>
					<span>Texto superior opcional</span>

					<input
						type="text"
						name="services_eyebrow"
						value={page.services_eyebrow ?? ""}
						maxlength="100"
					/>
				</label>

				<label class="full">
					<span>Título da seção</span>

					<input
						type="text"
						name="services_title"
						value={page.services_title}
						maxlength="180"
						required
					/>
				</label>

				<label class="full">
					<span>Descrição da seção</span>

					<textarea
						name="services_description"
						rows="4"
						maxlength="800"
						required
					>{page.services_description}</textarea>
				</label>
			</div>
		</section>

		<section class="panel">
			<header>
				<div>
					<span>Catálogo e preços</span>
					<h2>Introdução dos grids comerciais</h2>
					<p>
						Os itens e pacotes são gerenciados no Catálogo; estes campos controlam o texto da seção pública.
					</p>
				</div>
			</header>

			<div class="fields">
				<label>
					<span>Texto superior opcional</span>

					<input
						type="text"
						name="pricing_eyebrow"
						value={page.pricing_eyebrow ?? ""}
						maxlength="100"
					/>
				</label>

				<label class="full">
					<span>Título da seção</span>

					<input
						type="text"
						name="pricing_title"
						value={page.pricing_title}
						maxlength="180"
						required
					/>
				</label>

				<label class="full">
					<span>Descrição da seção</span>

					<textarea
						name="pricing_description"
						rows="4"
						maxlength="800"
						required
					>{page.pricing_description}</textarea>
				</label>

				<label class="full">
					<span>Aviso abaixo do catálogo</span>

					<textarea
						name="pricing_disclaimer"
						rows="4"
						maxlength="1200"
						placeholder="Valores podem variar conforme..."
					>{page.pricing_disclaimer ?? ""}</textarea>

					<small>
						Use para explicar peças, licenças, deslocamento, avaliação e condições de orçamento.
					</small>
				</label>
			</div>
		</section>

		<section class="panel">
			<header>
				<div>
					<span>CTA final</span>
					<h2>Chamada de encerramento</h2>
					<p>
						Última oportunidade de converter o visitante em uma conversa pelo WhatsApp.
					</p>
				</div>
			</header>

			<div class="fields">
				<label>
					<span>Texto superior</span>

					<input
						type="text"
						name="cta_eyebrow"
						value={page.cta_eyebrow}
						maxlength="100"
						required
					/>
				</label>

				<label class="full">
					<span>Título</span>

					<input
						type="text"
						name="cta_title"
						value={page.cta_title}
						maxlength="180"
						required
					/>
				</label>

				<label class="full">
					<span>Descrição</span>

					<textarea
						name="cta_description"
						rows="4"
						maxlength="800"
						required
					>{page.cta_description}</textarea>
				</label>

				<label>
					<span>Texto do botão principal</span>

					<input
						type="text"
						name="cta_button_label"
						value={page.cta_button_label}
						maxlength="80"
						required
					/>
				</label>

				<label class="full">
					<span>Mensagem do WhatsApp</span>

					<textarea
						name="cta_message"
						rows="4"
						maxlength="1200"
						required
					>{page.cta_message}</textarea>
				</label>

				<label>
					<span>Texto do botão secundário</span>

					<input
						type="text"
						name="cta_secondary_label"
						value={page.cta_secondary_label ?? ""}
						maxlength="80"
						placeholder="Conhecer outra divisão"
					/>
				</label>

				<label>
					<span>Destino do botão secundário</span>

					<input
						type="text"
						name="cta_secondary_href"
						value={page.cta_secondary_href ?? ""}
						maxlength="500"
						placeholder="/"
					/>

					<small>
						Preencha texto e destino juntos ou deixe ambos vazios.
					</small>
				</label>
			</div>
		</section>

		<footer class="form-footer">
			<a href="/admin/pages">
				Cancelar
			</a>

			<button type="submit">
				Salvar todas as alterações
			</button>
		</footer>
	</form>
</AdminLayout>

<style>
	.preview {
		display: inline-flex;
		padding: 11px 15px;
		border: 1px solid
			rgba(105, 145, 205, 0.3);
		border-radius: 10px;
		background: rgba(41, 101, 190, 0.12);
		color: #b9d4fa;
		font-size: 0.72rem;
		text-decoration: none;
	}

	.message {
		margin: 0 0 20px;
		padding: 15px 17px;
		border-radius: 11px;
		font-size: 0.78rem;
	}

	.success {
		border: 1px solid
			rgba(75, 220, 145, 0.25);
		background: rgba(35, 150, 100, 0.12);
		color: #8be2b6;
	}

	.error {
		border: 1px solid
			rgba(255, 100, 100, 0.25);
		background: rgba(160, 30, 40, 0.13);
		color: #ffb1b6;
	}

	form {
		display: grid;
		gap: 20px;
	}

	.panel {
		padding: 28px;
		border: 1px solid
			rgba(105, 145, 205, 0.2);
		border-radius: 18px;
		background: rgba(7, 17, 31, 0.82);
	}

	.panel > header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 26px;
	}

	.panel header span {
		color: #619fea;
		letter-spacing: 0.14em;
		font-size: 0.61rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.panel header p {
		max-width: 720px;
		margin: 9px 0 0;
		color: #70839a;
		font-size: 0.67rem;
		line-height: 1.55;
	}

	h2 {
		margin: 7px 0 0;
		font-size: 1.25rem;
		font-weight: 500;
	}

	.fields {
		display: grid;
		grid-template-columns:
			repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	label {
		display: grid;
		align-content: start;
		gap: 8px;
	}

	label > span {
		color: #99abc1;
		font-size: 0.7rem;
		font-weight: 600;
	}

	label small {
		color: #687b93;
		font-size: 0.61rem;
		line-height: 1.5;
	}

	.full {
		grid-column: 1 / -1;
	}

	input[type="text"],
	textarea {
		width: 100%;
		padding: 13px 14px;
		border: 1px solid
			rgba(105, 145, 205, 0.28);
		border-radius: 10px;
		outline: none;
		background: rgba(2, 8, 16, 0.72);
		color: #f7faff;
		font: inherit;
		line-height: 1.5;
	}

	input:focus,
	textarea:focus {
		border-color: #428eff;
		box-shadow:
			0 0 0 3px
			rgba(48, 132, 255, 0.12);
	}

	.toggle {
		display: flex;
		align-items: center;
		gap: 9px;
	}

	.toggle input {
		width: 18px;
		height: 18px;
		accent-color: #347dff;
	}

	.form-footer {
		position: sticky;
		bottom: 16px;
		z-index: 4;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 14px;
		padding: 14px;
		border: 1px solid
			rgba(105, 145, 205, 0.22);
		border-radius: 14px;
		background:
			rgba(5, 13, 25, 0.94);
		backdrop-filter: blur(14px);
		box-shadow:
			0 18px 44px
			rgba(0, 0, 0, 0.3);
	}

	.form-footer a {
		padding: 12px 16px;
		color: #8497af;
		font-size: 0.75rem;
		text-decoration: none;
	}

	.form-footer button {
		padding: 13px 20px;
		border: 1px solid
			rgba(80, 151, 255, 0.58);
		border-radius: 10px;
		cursor: pointer;
		background:
			linear-gradient(
				135deg,
				#245fc7,
				#347dff
			);
		color: white;
		font-weight: 700;
	}

	@media (max-width: 700px) {
		.fields {
			grid-template-columns: 1fr;
		}

		.full {
			grid-column: auto;
		}

		.panel {
			padding: 22px 18px;
		}

		.panel > header {
			flex-direction: column;
		}

		.form-footer {
			bottom: 8px;
			align-items: stretch;
			flex-direction: column-reverse;
		}

		.form-footer a,
		.form-footer button {
			text-align: center;
		}
	}
</style>
