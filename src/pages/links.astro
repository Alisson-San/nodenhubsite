---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import SiteLogo from "../components/common/SiteLogo.astro";
import LinkCard from "../components/links/LinkCard.astro";

import {
	buildLinkItems,
} from "../data/links";

import {
	loadSiteConfig,
} from "../lib/site/siteRepository";

const site =
	await loadSiteConfig();

const linkItems =
	buildLinkItems(site);

const currentYear = new Date().getFullYear();
const serviceAreaText = site.serviceAreas.join(" • ");

const instagramHandle =
	site.socialLinks.find(
		(item) =>
			item.isActive &&
			item.platform === "instagram",
	)?.username ?? "@noden.hub";

const siteLabel = site.url
	.replace(/^https?:\/\//, "")
	.replace(/\/$/, "");
---

<BaseLayout
	site={site}
	title="Links — Noden Technology Hub"
	description="Acesse os principais canais de contato, redes sociais e informações da Noden Technology Hub."
	canonical="/links"
>
	<Fragment slot="head">
		<link rel="preconnect" href="https://fonts.googleapis.com" />

		<link
			rel="preconnect"
			href="https://fonts.gstatic.com"
			crossorigin
		/>

		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
		/>

		<meta
			property="og:title"
			content="Links — Noden Technology Hub"
		/>

		<meta
			property="og:description"
			content="Contato, redes sociais e principais canais da Noden."
		/>

		<meta
			property="og:type"
			content="website"
		/>
	</Fragment>

	<div class="links-page">
		<div class="links-page__glow" aria-hidden="true"></div>

		<main class="links-shell">
			<header class="links-profile">
				<div class="links-profile__logo">
					<SiteLogo
						size="lg"
						showTagline={true}
						idPrefix="links-page-logo"
					/>
				</div>

				<span class="links-profile__handle">
					{instagramHandle}
				</span>

				<h1>
					Tecnologia para casa, games e negócios.
				</h1>

				<p>
					Suporte, performance e soluções digitais com
					atendimento próximo e preços justos.
				</p>

				<div
					class="links-profile__areas"
					aria-label="Divisões da Noden"
				>
					<span>HOME</span>
					<span>GAME</span>
					<span>DATA</span>
				</div>
			</header>

			<section
				class="links-list"
				aria-label="Links principais"
			>
				{
					linkItems.map((item) => (
						<LinkCard {...item} />
					))
				}
			</section>

			<aside class="links-service-area">
				<span aria-hidden="true"></span>

				<p>
					Atendimento em {serviceAreaText}
				</p>
			</aside>

			<footer class="links-footer">
				<p>
					© {currentYear} {site.legalName}
				</p>

				<a href={site.url}>
					{siteLabel}
				</a>
			</footer>
		</main>
	</div>
</BaseLayout>

<style>
	:global(html) {
		background: #02050a;
	}

	:global(body) {
		min-width: 320px;
		min-height: 100vh;
		margin: 0;
		background: #02050a;
		color: #ffffff;
		font-family: "Inter", sans-serif;
	}

	:global(*) {
		box-sizing: border-box;
	}

	.links-page {
		position: relative;
		isolation: isolate;
		min-height: 100vh;
		overflow: hidden;
		padding: 44px 0 32px;
		background:
			radial-gradient(
				circle at 50% -10%,
				rgba(42, 104, 224, 0.18),
				transparent 37%
			),
			radial-gradient(
				circle at 95% 50%,
				rgba(105, 44, 213, 0.08),
				transparent 36%
			),
			#02050a;
	}

	.links-page__glow {
		position: absolute;
		z-index: -1;
		top: -210px;
		left: 50%;
		width: 620px;
		height: 620px;
		transform: translateX(-50%);
		border: 1px solid rgba(93, 145, 221, 0.055);
		border-radius: 999px;
		pointer-events: none;
	}

	.links-shell {
		width: min(100% - 28px, 620px);
		margin: 0 auto;
	}

	.links-profile {
		display: flex;
		align-items: center;
		flex-direction: column;
		text-align: center;
	}

	.links-profile__logo {
		display: flex;
		justify-content: center;
	}

	.links-profile__logo :global(.site-logo) {
		align-items: center;
	}

	.links-profile__handle {
		margin-top: 20px;
		color: #7799ca;
		font-size: 0.61rem;
		font-weight: 600;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}

	.links-profile h1 {
		max-width: 560px;
		margin: 19px 0 0;
		font-size: clamp(2.1rem, 10vw, 4rem);
		font-weight: 400;
		letter-spacing: -0.055em;
		line-height: 1;
	}

	.links-profile > p {
		max-width: 470px;
		margin: 20px 0 0;
		color: #8e9db1;
		font-size: 0.82rem;
		line-height: 1.65;
	}

	.links-profile__areas {
		display: flex;
		margin-top: 23px;
		justify-content: center;
		gap: 7px;
		flex-wrap: wrap;
	}

	.links-profile__areas span {
		padding: 7px 10px;
		border: 1px solid rgba(103, 145, 207, 0.17);
		border-radius: 999px;
		background: rgba(20, 44, 80, 0.25);
		color: #7793bb;
		font-size: 0.51rem;
		font-weight: 600;
		letter-spacing: 0.17em;
	}

	.links-list {
		display: flex;
		margin-top: 38px;
		flex-direction: column;
		gap: 11px;
	}

	.links-service-area {
		display: flex;
		margin-top: 29px;
		padding: 15px 17px;
		align-items: flex-start;
		gap: 10px;
		border: 1px solid rgba(97, 135, 190, 0.11);
		border-radius: 15px;
		background: rgba(7, 16, 30, 0.5);
	}

	.links-service-area > span {
		width: 7px;
		height: 7px;
		margin-top: 5px;
		flex-shrink: 0;
		border-radius: 999px;
		background: #24d49b;
		box-shadow: 0 0 12px rgba(36, 212, 155, 0.48);
	}

	.links-service-area p {
		margin: 0;
		color: #78889e;
		font-size: 0.65rem;
		line-height: 1.6;
	}

	.links-footer {
		display: flex;
		margin-top: 38px;
		padding-top: 22px;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		border-top: 1px solid rgba(105, 142, 196, 0.1);
	}

	.links-footer p,
	.links-footer a {
		margin: 0;
		color: #57677d;
		font-size: 0.59rem;
		line-height: 1.5;
		text-decoration: none;
	}

	.links-footer a:hover {
		color: #93a7c2;
	}

	.links-footer a:focus-visible {
		border-radius: 4px;
		outline: 2px solid rgba(70, 147, 255, 0.78);
		outline-offset: 4px;
	}

	@media (min-width: 700px) {
		.links-page {
			padding-top: 66px;
		}

		.links-list {
			margin-top: 44px;
		}
	}

	@media (max-width: 420px) {
		.links-page {
			padding-top: 34px;
		}

		.links-profile h1 {
			font-size: clamp(2rem, 11.5vw, 3rem);
		}

		.links-footer {
			align-items: flex-start;
			flex-direction: column;
			gap: 7px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		:global(html) {
			scroll-behavior: auto;
		}
	}
</style>
