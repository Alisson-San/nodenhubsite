---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteLogo from "../../components/common/SiteLogo.astro";
import SiteHeader from "../../components/common/SiteHeader.astro";
import SiteFooter from "../../components/common/SiteFooter.astro";

const previewNavigation = [
	{
		label: "Identidade",
		href: "#identidade",
	},
	{
		label: "Variações",
		href: "#variacoes",
	},
];
---

<BaseLayout title="Componentes — Noden">
	<Fragment slot="head">
		<meta name="robots" content="noindex, nofollow" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link
			rel="preconnect"
			href="https://fonts.gstatic.com"
			crossorigin
		/>

		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
		/>
	</Fragment>

	<SiteHeader
		sticky={false}
		navigation={previewNavigation}
		ctaLabel="Ver componentes"
		ctaHref="#variacoes"
		logoIdPrefix="preview-header-logo"
	/>

	<main id="identidade">
		<header>
			<span>COMPONENT PREVIEW</span>
			<h1>Identidade compartilhada</h1>
			<p>
				Visualização temporária dos componentes reutilizáveis da Noden.
			</p>
		</header>

		<section id="variacoes">
			<div class="preview-card">
				<span class="preview-label">SMALL</span>

				<SiteLogo
					size="sm"
					idPrefix="preview-logo-small"
				/>
			</div>

			<div class="preview-card">
				<span class="preview-label">MEDIUM</span>

				<SiteLogo
					size="md"
					idPrefix="preview-logo-medium"
					showTagline={true}
				/>
			</div>

			<div class="preview-card">
				<span class="preview-label">LARGE</span>

				<SiteLogo
					size="lg"
					idPrefix="preview-logo-large"
					showTagline={true}
				/>
			</div>

			<div class="preview-card">
				<span class="preview-label">SEM LINK</span>

				<SiteLogo
					href=""
					size="md"
					idPrefix="preview-logo-static"
				/>
			</div>
		</section>
	</main>
	<SiteFooter logoIdPrefix="preview-footer-logo" />
</BaseLayout>

<style>
	:global(html) {
		scroll-behavior: smooth;
		background: #02050a;
	}

	main,
	section {
		scroll-margin-top: 90px;
	}


	:global(body) {
		min-height: 100vh;
		margin: 0;
		background:
			radial-gradient(
				circle at 70% 10%,
				rgba(36, 102, 220, 0.12),
				transparent 30%
			),
			#02050a;
		color: #ffffff;
		font-family: "Inter", sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	main {
		width: min(100% - 40px, 920px);
		margin: 0 auto;
		padding: 80px 0;
	}

	header {
		margin-bottom: 42px;
	}

	header > span,
	.preview-label {
		color: #7592bb;
		font-size: 0.58rem;
		font-weight: 600;
		letter-spacing: 0.24em;
	}

	h1 {
		margin: 14px 0 0;
		font-size: clamp(2.5rem, 7vw, 5rem);
		font-weight: 400;
		letter-spacing: -0.055em;
		line-height: 0.98;
	}

	header p {
		max-width: 520px;
		margin: 20px 0 0;
		color: #8e9eb4;
		font-size: 0.95rem;
		line-height: 1.6;
	}

	section {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 16px;
	}

	.preview-card {
		display: flex;
		min-height: 190px;
		padding: 24px;
		flex-direction: column;
		justify-content: space-between;
		border: 1px solid rgba(104, 139, 192, 0.15);
		border-radius: 22px;
		background:
			linear-gradient(
				180deg,
				rgba(15, 31, 54, 0.68),
				rgba(7, 13, 23, 0.52)
			);
	}

	@media (max-width: 680px) {
		main {
			padding: 60px 0;
		}

		section {
			grid-template-columns: 1fr;
		}

		.preview-card {
			min-height: 160px;
		}
	}
</style>