---
interface Props {
	index: number;
	title: string;
	description: string;
	features?: string[];
	badge?: string;
}

const {
	index,
	title,
	description,
	features = [],
	badge,
} = Astro.props;

const displayNumber = String(index).padStart(2, "0");
---

<article class="service-card">
	<div class="service-card__top">
		<span class="service-card__number" aria-hidden="true">
			{displayNumber}
		</span>

		{
			badge && (
				<span class="service-card__badge">
					{badge}
				</span>
			)
		}
	</div>

	<div class="service-card__content">
		<h3>{title}</h3>

		<p>{description}</p>
	</div>

	{
		features.length > 0 && (
			<ul>
				{features.map((feature) => (
					<li>
						<svg
							viewBox="0 0 20 20"
							aria-hidden="true"
						>
							<path
								d="m5.5 10.5 3 3 6-7"
								fill="none"
								stroke="currentColor"
								stroke-width="1.8"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>

						<span>{feature}</span>
					</li>
				))}
			</ul>
		)
	}

	<div class="service-card__line" aria-hidden="true"></div>
</article>

<style>
	.service-card,
	.service-card * {
		box-sizing: border-box;
	}

	.service-card {
		position: relative;
		display: flex;
		min-height: 100%;
        min-width: 0;
	    min-height: 100%;
		padding: 28px;
		overflow: hidden;
		flex-direction: column;
		border: 1px solid rgba(103, 143, 201, 0.15);
		border-radius: 23px;
		background:
			linear-gradient(
				145deg,
				rgba(15, 32, 57, 0.77),
				rgba(6, 14, 27, 0.86)
			);
		transition:
			border-color 180ms ease,
			transform 180ms ease,
			background-color 180ms ease;
	}


	.service-card__top {
		display: flex;
		min-height: 26px;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
	}

	.service-card__number {
		color: color-mix(
			in srgb,
			var(--service-accent) 64%,
			#8192aa
		);
		font-size: 0.59rem;
		font-weight: 600;
		letter-spacing: 0.2em;
	}

	.service-card__badge {
		padding: 6px 9px;
		border: 1px solid
			color-mix(
				in srgb,
				var(--service-accent) 24%,
				transparent
			);
		border-radius: 999px;
		background:
			color-mix(
				in srgb,
				var(--service-accent) 9%,
				transparent
			);
		color: color-mix(
			in srgb,
			var(--service-accent) 57%,
			#ffffff
		);
		font-size: 0.51rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.service-card__content {
		margin-top: 42px;
	}

	.service-card h3 {
		margin: 0;
		color: #ffffff;
		font-size: clamp(1.35rem, 2.4vw, 1.75rem);
		font-weight: 400;
		letter-spacing: -0.035em;
		line-height: 1.15;
        text-wrap: balance;
	}

	.service-card__content > p {
		margin: 16px 0 0;
		color: #8797ad;
		font-size: 0.78rem;
		line-height: 1.7;
	}

	.service-card ul {
		display: flex;
		margin: 27px 0 0;
		padding: 22px 0 0;
		flex-direction: column;
		gap: 12px;
		border-top: 1px solid rgba(104, 143, 199, 0.1);
		list-style: none;
	}

	.service-card li {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		color: #9aa9bc;
		font-size: 0.7rem;
		line-height: 1.5;
	}

	.service-card li svg {
		width: 17px;
		height: 17px;
		margin-top: 1px;
		flex-shrink: 0;
		color: color-mix(
			in srgb,
			var(--service-accent) 70%,
			#ffffff
		);
	}

	.service-card__line {
		position: absolute;
		right: 28px;
		bottom: 0;
		left: 28px;
		height: 1px;
		background:
			linear-gradient(
				90deg,
				transparent,
				color-mix(
					in srgb,
					var(--service-accent) 56%,
					transparent
				),
				transparent
			);
		opacity: 0;
		transition: opacity 180ms ease;
	}

	.service-card:hover {
		border-color:
			color-mix(
				in srgb,
				var(--service-accent) 34%,
				transparent
			);
		background:
			linear-gradient(
				145deg,
				rgba(18, 39, 70, 0.88),
				rgba(7, 17, 32, 0.94)
			);
		transform: translateY(-3px);
	}

	.service-card:hover .service-card__line {
		opacity: 1;
	}

	@media (max-width: 600px) {
			.service-card {
                min-height: auto;
                padding: 24px;
                border-radius: 20px;
            }

            .service-card__content {
                margin-top: 28px;
            }

            .service-card h3 {
                font-size: 1.45rem;
            }

            .service-card__content > p {
                font-size: 0.78rem;
            }

            .service-card ul {
                margin-top: 23px;
                padding-top: 20px;
            }
	}

	@media (prefers-reduced-motion: reduce) {
		.service-card,
		.service-card__line {
			transition: none;
		}
	}
</style>