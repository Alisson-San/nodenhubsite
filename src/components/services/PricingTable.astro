---
import {
	formatCurrency,
} from "../../lib/formatting";

import {
	getWhatsAppUrl,
} from "../../config/site";

import {
	getCatalogIconSymbol,
} from "../../lib/catalog/icons";

import type {
	CatalogItemKind,
	PricingItem,
	ServiceDivision,
} from "../../types/services";

interface Props {
	id?: string;
	division: ServiceDivision;
	eyebrow?: string;
	title: string;
	description?: string;
	items: PricingItem[];
	disclaimer?: string;
}

interface CatalogGroup {
	key: string;
	title: string;
	description?: string;
	iconKey?: string;
	color: string;
	items: PricingItem[];
}

const {
	id = "precos",
	division,
	eyebrow = "VALORES",
	title,
	description,
	items,
	disclaimer = "Os valores podem variar conforme o estado do equipamento, complexidade do serviço, peças necessárias e deslocamento.",
} = Astro.props;

const titleId =
	`${id}-title`;

const searchId =
	`${id}-search`;

const itemKindLabels:
	Record<
		CatalogItemKind,
		string
	> = {
		service: "Serviços",
		package: "Pacotes",
		product: "Produtos",
		consulting: "Consultoria",
	};

const itemKindSingularLabels:
	Record<
		CatalogItemKind,
		string
	> = {
		service: "Serviço",
		package: "Pacote",
		product: "Produto",
		consulting: "Consultoria",
	};

const fallbackGroupDescriptions:
	Record<
		CatalogItemKind,
		string
	> = {
		service:
			"Serviços disponíveis nesta área da Noden.",

		package:
			"Combinações de serviços pensadas para entregar uma solução mais completa.",

		product:
			"Produtos físicos ou digitais disponíveis nesta área.",

		consulting:
			"Diagnósticos, orientações e projetos especializados.",
	};

const resolveItemKind = (
	item: PricingItem,
): CatalogItemKind =>
	item.itemKind ??
	"service";

const resolvePrice = (
	item: PricingItem,
): string => {
	if (item.priceLabel) {
		return item.priceLabel;
	}

	if (
		typeof item.price ===
		"number"
	) {
		return formatCurrency(
			item.price,
		);
	}

	return "Sob consulta";
};

const resolveWhatsAppUrl = (
	item: PricingItem,
): string => {
	const message =
		item.ctaMessage ??
		`Olá! Vim pela página Noden ${division.toUpperCase()} e gostaria de saber mais sobre o serviço: ${item.name}.`;

	return getWhatsAppUrl(
		message,
	);
};

const buildSearchText = (
	item: PricingItem,
): string =>
	[
		item.name,
		item.description,
		item.category?.name,
		item.category?.description,
		item.tier?.name,
		item.tier?.description,
		itemKindSingularLabels[
			resolveItemKind(
				item,
			)
		],
		...(item.features ?? []),
		...(
			item.badges ?? []
		).map(
			(badge) =>
				badge.name,
		),
	]
		.filter(Boolean)
		.join(" ");

const groupsByKey =
	new Map<
		string,
		CatalogGroup
	>();

for (const item of items) {
	const kind =
		resolveItemKind(
			item,
		);

	const category =
		item.category;

	const key =
		category
			? `category:${category.slug}`
			: `kind:${kind}`;

	const existing =
		groupsByKey.get(
			key,
		);

	if (existing) {
		existing.items.push(
			item,
		);

		continue;
	}

	groupsByKey.set(
		key,
		{
			key,

			title:
				category?.name ??
				itemKindLabels[kind],

			description:
				category?.description ??
				fallbackGroupDescriptions[
					kind
				],

			iconKey:
				category?.iconKey,

			color:
				category?.color ??
				"var(--service-accent)",

			items: [
				item,
			],
		},
	);
}

const groups =
	[
		...groupsByKey
			.values(),
	];

const availableKinds =
	[
		...new Set<
			CatalogItemKind
		>(
			items.map(
				resolveItemKind,
			),
		),
	];

const hasInteractiveControls =
	items.length > 1;
---

<section
	class="pricing-table"
	id={id}
	aria-labelledby={titleId}
	data-catalog-root
>
	<header class="pricing-table__header">
		<div>
			<span>{eyebrow}</span>

			<h2 id={titleId}>
				{title}
			</h2>
		</div>

		{
			description && (
				<p>{description}</p>
			)
		}
	</header>

	{
		hasInteractiveControls && (
			<section
				class="catalog-controls"
				aria-label="Busca e filtros do catálogo"
				data-catalog-controls
				hidden
			>
				<div class="catalog-search">
					<label
						class="sr-only"
						for={searchId}
					>
						Buscar no catálogo
					</label>

					<svg
						viewBox="0 0 20 20"
						aria-hidden="true"
					>
						<circle
							cx="8.5"
							cy="8.5"
							r="5.5"
							fill="none"
							stroke="currentColor"
							stroke-width="1.6"
						/>

						<path
							d="m12.5 12.5 4 4"
							fill="none"
							stroke="currentColor"
							stroke-width="1.6"
							stroke-linecap="round"
						/>
					</svg>

					<input
						id={searchId}
						type="search"
						placeholder="Buscar serviço, pacote, recurso..."
						autocomplete="off"
						data-catalog-search
					/>

					<button
						type="button"
						class="catalog-search__clear"
						aria-label="Limpar busca"
						data-clear-search
						hidden
					>
						×
					</button>
				</div>

				{
					availableKinds.length > 1 && (
						<div class="catalog-filter-group">
							<span>Tipo de item</span>

							<div
								class="catalog-filter-scroll"
								role="group"
								aria-label="Filtrar por tipo"
							>
								<button
									type="button"
									class="catalog-filter is-active"
									data-filter-kind=""
									aria-pressed="true"
								>
									Todos
								</button>

								{
									availableKinds.map(
										(kind) => (
											<button
												type="button"
												class="catalog-filter"
												data-filter-kind={kind}
												aria-pressed="false"
											>
												{itemKindLabels[kind]}
											</button>
										),
									)
								}
							</div>
						</div>
					)
				}

				<footer class="catalog-controls__footer">
					<p
						aria-live="polite"
						data-result-count
					>
						{items.length} resultados
					</p>

					<button
						type="button"
						data-reset-filters
						hidden
					>
						Limpar filtros
					</button>
				</footer>
			</section>
		)
	}

	{
		items.length === 0 ? (
			<p class="catalog-empty catalog-empty--initial">
				Nenhum item disponível no momento.
			</p>
		) : (
			<div class="catalog-groups">
				{
					groups.map(
						(group) => (
							<section
								class="catalog-group"
								data-catalog-group
								style={`--group-color:${group.color};`}
								aria-labelledby={`${id}-${group.key.replace(
									/[^a-z0-9-]/gi,
									"-",
								)}`}
							>
								<header class="catalog-group__header">
									<div class="catalog-group__identity">
										<span
											class="catalog-group__icon"
											aria-hidden="true"
										>
											{getCatalogIconSymbol(
												group.iconKey,
												"•",
											)}
										</span>

										<div>
											<p>Categoria</p>

											<h3
												id={`${id}-${group.key.replace(
													/[^a-z0-9-]/gi,
													"-",
												)}`}
											>
												{group.title}
											</h3>
										</div>
									</div>

									{
										group.description && (
											<p class="catalog-group__description">
												{group.description}
											</p>
										)
									}

									<span
										class="catalog-group__count"
										data-group-count
									>
										{group.items.length === 1
											? "1 item"
											: `${group.items.length} itens`}
									</span>
								</header>

								<div class="pricing-table__items">
									{
										group.items.map(
											(item) => {
												const itemKind =
													resolveItemKind(
														item,
													);

												const badges =
													(
														item.badges ??
														[]
													).slice(
														0,
														3,
													);

												const legacyBadge =
													badges.length ===
														0 &&
													item.badge &&
													!item.tier
														? item.badge
														: undefined;

												const featuredFallback =
													badges.length ===
														0 &&
													!legacyBadge &&
													item.featured;

												const hasPromotion =
													typeof item.price ===
														"number" &&
													typeof item.compareAtPrice ===
														"number" &&
													item.compareAtPrice >
														item.price;

												const saving =
													hasPromotion
														? item.compareAtPrice! -
															item.price!
														: 0;

												return (
													<article
														class:list={[
															"pricing-card",
															{
																"is-featured":
																	item.featured,
																"has-promotion":
																	hasPromotion,
															},
														]}
														data-catalog-card
														data-kind={itemKind}
														data-search={buildSearchText(
															item,
														)}
													>
														<div class="pricing-card__top">
															<div class="pricing-card__classification">
																<span class="pricing-card__kind">
																	{
																		itemKindSingularLabels[
																			itemKind
																		]
																	}
																</span>

																{
																	item.tier && (
																		<span
																			class="pricing-card__tier"
																			style={`--tier-color:${item.tier.color};`}
																		>
																			{item.tier.name}
																		</span>
																	)
																}
															</div>

															{
																(
																	badges.length >
																		0 ||
																	legacyBadge ||
																	featuredFallback
																) && (
																	<div
																		class="pricing-card__badges"
																		aria-label="Destaques"
																	>
																		{
																			badges.map(
																				(
																					badge,
																				) => (
																					<span
																						class="pricing-card__badge pricing-card__badge--custom"
																						style={`
																							--badge-text:${badge.textColor};
																							--badge-background:${badge.backgroundColor};
																							--badge-border:${badge.borderColor};
																						`}
																					>
																						<i aria-hidden="true">
																							{getCatalogIconSymbol(
																								badge.iconKey,
																								"🏷️",
																							)}
																						</i>

																						{badge.name}
																					</span>
																				),
																			)
																		}

																		{
																			legacyBadge && (
																				<span class="pricing-card__badge">
																					{legacyBadge}
																				</span>
																			)
																		}

																		{
																			featuredFallback && (
																				<span class="pricing-card__badge">
																					🔥 Mais procurado
																				</span>
																			)
																		}
																	</div>
																)
															}

															<h4>{item.name}</h4>

															<p>{item.description}</p>
														</div>

														<div class="pricing-card__price">
															{
																hasPromotion && (
																	<div class="pricing-card__old-price">
																		<span>De</span>

																		<del>
																			{formatCurrency(
																				item.compareAtPrice!,
																			)}
																		</del>
																	</div>
																)
															}

															<div class="pricing-card__current-price">
																{
																	item.pricePrefix && (
																		<span class="pricing-card__prefix">
																			{item.pricePrefix}
																		</span>
																	)
																}

																<strong>
																	{resolvePrice(
																		item,
																	)}
																</strong>

																{
																	item.priceSuffix && (
																		<span class="pricing-card__suffix">
																			{item.priceSuffix}
																		</span>
																	)
																}
															</div>

															{
																hasPromotion && (
																	<span class="pricing-card__saving">
																		Economize{" "}
																		{formatCurrency(
																			saving,
																		)}
																	</span>
																)
															}
														</div>

														{
															item.features &&
																item.features.length >
																	0 && (
																	<ul>
																		{
																			item.features.map(
																				(
																					feature,
																				) => (
																					<li>
																						<svg
																							viewBox="0 0 20 20"
																							aria-hidden="true"
																						>
																							<path
																								d="m5.5 10.5 3 3 6-7"
																								fill="none"
																								stroke="currentColor"
																								stroke-width="1.8"
																								stroke-linecap="round"
																								stroke-linejoin="round"
																							/>
																						</svg>

																						{feature}
																					</li>
																				),
																			)
																		}
																	</ul>
																)
														}

														{
															item.note && (
																<p class="pricing-card__note">
																	{item.note}
																</p>
															)
														}

														<footer class="pricing-card__footer">
															<a
																href={resolveWhatsAppUrl(
																	item,
																)}
>
																{
																	item.ctaLabel ??
																	"Consultar pelo WhatsApp"
																}

																<svg
																	viewBox="0 0 20 20"
																	aria-hidden="true"
																>
																	<path
																		d="M6 14 14 6M8 6h6v6"
																		fill="none"
																		stroke="currentColor"
																		stroke-width="1.7"
																		stroke-linecap="round"
																		stroke-linejoin="round"
																	/>
																</svg>
															</a>
														</footer>
													</article>
												);
											},
										)
									}
								</div>
							</section>
						),
					)
				}
			</div>
		)
	}

	<p
		class="catalog-empty"
		data-catalog-empty
		hidden
	>
		Nenhum item corresponde à busca ou ao tipo selecionado.
	</p>

	<p class="pricing-table__disclaimer">
		{disclaimer}
	</p>
</section>

<script>
	const normalizeCatalogText = (
		value: string,
	): string =>
		value
			.normalize("NFD")
			.replace(
				/[\u0300-\u036f]/g,
				"",
			)
			.toLocaleLowerCase(
				"pt-BR",
			)
			.trim();

	type CatalogUrlState = {
		query: string;
		kind: string;
	};

	const catalogKindToUrl:
		Record<string, string> = {
			service: "servico",
			package: "pacote",
			product: "produto",
			consulting: "consultoria",
		};

	const catalogUrlToKind:
		Record<string, string> = {
			servico: "service",
			pacote: "package",
			produto: "product",
			consultoria: "consulting",
		};

	const readCatalogUrlState =
		(): CatalogUrlState => {
			const params =
				new URLSearchParams(
					window.location.search,
				);

			return {
				query:
					params.get(
						"busca",
					) ?? "",

				kind:
					catalogUrlToKind[
						params.get(
							"tipo",
						) ?? ""
					] ?? "",
			};
		};

	const writeCatalogUrlState = (
		state: CatalogUrlState,
		catalogId: string,
	): void => {
		const url =
			new URL(
				window.location.href,
			);

		const query =
			state.query.trim();

		if (query) {
			url.searchParams.set(
				"busca",
				query,
			);
		} else {
			url.searchParams.delete(
				"busca",
			);
		}

		const kind =
			catalogKindToUrl[
				state.kind
			] ?? "";

		if (kind) {
			url.searchParams.set(
				"tipo",
				kind,
			);
		} else {
			url.searchParams.delete(
				"tipo",
			);
		}

		if (
			(query || kind) &&
			catalogId
		) {
			url.hash =
				`#${catalogId}`;
		}

		const nextUrl =
			`${url.pathname}${url.search}${url.hash}`;

		const currentUrl =
			`${window.location.pathname}${window.location.search}${window.location.hash}`;

		if (nextUrl === currentUrl) {
			return;
		}

		window.history.replaceState(
			window.history.state,
			"",
			nextUrl,
		);
	};

	document
		.querySelectorAll<HTMLElement>(
			"[data-catalog-root]",
		)
		.forEach((root) => {
			if (
				root.dataset
					.catalogInitialized ===
				"true"
			) {
				return;
			}

			const controls =
				root.querySelector<HTMLElement>(
					"[data-catalog-controls]",
				);

			if (!controls) {
				return;
			}

			root.dataset
				.catalogInitialized =
					"true";

			controls.hidden =
				false;

			const cards =
				[
					...root
						.querySelectorAll<HTMLElement>(
							"[data-catalog-card]",
						),
				];

			const groups =
				[
					...root
						.querySelectorAll<HTMLElement>(
							"[data-catalog-group]",
						),
				];

			const searchInput =
				root.querySelector<HTMLInputElement>(
					"[data-catalog-search]",
				);

			const clearSearch =
				root.querySelector<HTMLButtonElement>(
					"[data-clear-search]",
				);

			const resetButton =
				root.querySelector<HTMLButtonElement>(
					"[data-reset-filters]",
				);

			const resultCount =
				root.querySelector<HTMLElement>(
					"[data-result-count]",
				);

			const emptyState =
				root.querySelector<HTMLElement>(
					"[data-catalog-empty]",
				);

			const state =
				readCatalogUrlState();

			if (
				state.kind &&
				!cards.some(
					(card) =>
						card.dataset.kind ===
						state.kind,
				)
			) {
				state.kind = "";
			}

			const setKind =
				(value: string) => {
					state.kind =
						value;

					root
						.querySelectorAll<HTMLButtonElement>(
							"[data-filter-kind]",
						)
						.forEach(
							(button) => {
								const active =
									(
										button.dataset
											.filterKind ??
										""
									) === value;

								button.setAttribute(
									"aria-pressed",
									String(
										active,
									),
								);

								button.classList.toggle(
									"is-active",
									active,
								);
							},
						);
				};

			if (searchInput) {
				searchInput.value =
					state.query;
			}

			setKind(
				state.kind,
			);

			const applyFilters =
				() => {
					let visibleCount =
						0;

					const query =
						normalizeCatalogText(
							state.query,
						);

					for (
						const card of cards
					) {
						const searchable =
							normalizeCatalogText(
								card.dataset
									.search ??
									"",
							);

						const matchesQuery =
							!query ||
							searchable.includes(
								query,
							);

						const matchesKind =
							!state.kind ||
							card.dataset.kind ===
								state.kind;

						const visible =
							matchesQuery &&
							matchesKind;

						card.hidden =
							!visible;

						if (visible) {
							visibleCount +=
								1;
						}
					}

					for (
						const group of groups
					) {
						const groupCards =
							[
								...group
									.querySelectorAll<HTMLElement>(
										"[data-catalog-card]",
									),
							];

						const groupVisibleCount =
							groupCards.filter(
								(card) =>
									!card.hidden,
							).length;

						group.hidden =
							groupVisibleCount ===
							0;

						const count =
							group.querySelector<HTMLElement>(
								"[data-group-count]",
							);

						if (count) {
							count.textContent =
								groupVisibleCount ===
									1
									? "1 item"
									: `${groupVisibleCount} itens`;
						}
					}

					if (resultCount) {
						resultCount.textContent =
							visibleCount === 1
								? "1 resultado"
								: `${visibleCount} resultados`;
					}

					if (emptyState) {
						emptyState.hidden =
							visibleCount !==
							0;
					}

					const hasFilters =
						Boolean(
							state.query ||
							state.kind,
						);

					if (resetButton) {
						resetButton.hidden =
							!hasFilters;
					}

					if (clearSearch) {
						clearSearch.hidden =
							!state.query;
					}

					writeCatalogUrlState(
						state,
						root.id,
					);
				};

			root
				.querySelectorAll<HTMLButtonElement>(
					"[data-filter-kind]",
				)
				.forEach(
					(button) => {
						button.addEventListener(
							"click",
							() => {
								setKind(
									button.dataset
										.filterKind ??
										"",
								);

								applyFilters();
							},
						);
					},
				);

			searchInput?.addEventListener(
				"input",
				() => {
					state.query =
						searchInput.value;

					applyFilters();
				},
			);

			clearSearch?.addEventListener(
				"click",
				() => {
					state.query =
						"";

					if (searchInput) {
						searchInput.value =
							"";

						searchInput.focus();
					}

					applyFilters();
				},
			);

			resetButton?.addEventListener(
				"click",
				() => {
					state.query =
						"";

					if (searchInput) {
						searchInput.value =
							"";
					}

					setKind(
						"",
					);

					applyFilters();

					searchInput?.focus();
				},
			);

			applyFilters();
		});
</script>

