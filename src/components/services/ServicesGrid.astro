---
import ServiceCard from "./ServiceCard.astro";

import type {
	ServiceItem,
} from "../../types/services";

interface Props {
	id?: string;
	eyebrow?: string;
	title: string;
	description?: string;
	services: ServiceItem[];
}

const {
	id = "servicos",
	eyebrow = "SERVIÇOS",
	title,
	description,
	services,
} = Astro.props;

const titleId = `${id}-title`;
---

<section
	class="services-grid"
	id={id}
	aria-labelledby={titleId}
>
	<header class="services-grid__header">
        <div class="services-grid__eyebrow">
            <span>{eyebrow}</span>
            <div aria-hidden="true"></div>
        </div>

        <div class="services-grid__heading">
            <h2 id={titleId}>
                {title}
            </h2>

            {
                description && (
                    <p>{description}</p>
                )
            }
        </div>
    </header>

	<div class="services-grid__items">
		{
			services.map((service, index) => (
				<ServiceCard
					index={index + 1}
					title={service.title}
					description={service.description}
					features={service.features}
					badge={service.badge}
				/>
			))
		}
	</div>
</section>

<style>
	.services-grid,
	.services-grid * {
		box-sizing: border-box;
	}

	.services-grid {
		width: min(100% - 40px, 1120px);
		margin: 0 auto;
		padding: 90px 0 40px;
		scroll-margin-top: 100px;
	}

    .services-grid__header {
        width: 100%;
    }

    .services-grid__eyebrow {
        display: flex;
        width: 100%;
        align-items: center;
        gap: 18px;
    }

    .services-grid__eyebrow span {
        flex-shrink: 0;
        color:
            color-mix(
                in srgb,
                var(--service-accent) 67%,
                #ffffff
            );
        font-size: 0.59rem;
        font-weight: 600;
        letter-spacing: 0.24em;
    }

    .services-grid__eyebrow div {
        width: 100%;
        height: 1px;
        background:
            linear-gradient(
                90deg,
                color-mix(
                    in srgb,
                    var(--service-accent) 32%,
                    transparent
                ),
                transparent 78%
            );
    }

    .services-grid__heading {
        display: grid;
        margin-top: 26px;
        grid-template-columns:
            minmax(0, 1.55fr)
            minmax(280px, 0.65fr);
        align-items: end;
        gap: clamp(42px, 7vw, 96px);
    }

    .services-grid h2 {
        max-width: 760px;
        margin: 0;
        font-size: clamp(2.5rem, 4.7vw, 4.25rem);
        font-weight: 300;
        letter-spacing: -0.055em;
        line-height: 0.98;
        text-wrap: balance;
    }

    .services-grid__heading p {
        max-width: 410px;
        margin: 0 0 3px;
        justify-self: end;
        color: #8798ae;
        font-size: 0.82rem;
        line-height: 1.7;
    }

    .services-grid__items {
        display: grid;
        width: 100%;
        margin-top: 48px;
        grid-template-columns:
            repeat(
                auto-fit,
                minmax(min(100%, 290px), 1fr)
            );
        gap: 16px;
}
	@media (max-width: 900px) {
		.services-grid__heading {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .services-grid h2 {
            max-width: 720px;
        }

        .services-grid__heading p {
            max-width: 620px;
            justify-self: start;
        }
	}

	@media (max-width: 620px) {
		.services-grid__eyebrow {
            gap: 12px;
        }

        .services-grid__heading {
            margin-top: 20px;
        }

        .services-grid h2 {
            font-size: clamp(2.35rem, 11vw, 3.4rem);
            line-height: 1;
        }
	}
</style>