---
import SiteLogo from "./SiteLogo.astro";

import {
	getWhatsAppUrl,
	siteConfig as fallbackSiteConfig,
} from "../../config/site";

import type {
	RuntimeSiteConfig,
} from "../../types/site";

interface FooterLink {
	label: string;
	href: string;
	external?: boolean;
}

interface Props {
	navigation?: FooterLink[];
	logoIdPrefix?: string;
	class?: string;
	site?: RuntimeSiteConfig;
}

const defaultNavigation: FooterLink[] = [
	{
		label: "Início",
		href: "/",
	},
	{
		label: "Noden Home",
		href: "/home",
	},
	{
		label: "Noden Game",
		href: "/game",
	},
	{
		label: "Noden Data",
		href: "/data",
	},
	{
		label: "Links",
		href: "/links",
	},
];

const {
	navigation = defaultNavigation,
	logoIdPrefix = "site-footer-logo",
	class: className = "",
	site = fallbackSiteConfig,
} = Astro.props;

const socialLinks: FooterLink[] =
	site.socialLinks
		.filter(
			(item) =>
				item.isActive &&
				item.platform !== "whatsapp" &&
				item.platform !== "website",
		)
		.sort(
			(a, b) =>
				a.sortOrder - b.sortOrder,
		)
		.map(
			(item) => ({
				label: item.label,
				href: item.url,
				external: true,
			}),
		);

const currentYear = new Date().getFullYear();

const phoneHref = `tel:${site.phone.replace(/[^\d+]/g, "")}`;

const serviceAreaText = site.serviceAreas.join(", ");

const whatsappUrl = getWhatsAppUrl(
	undefined,
	site,
);
---

<footer class:list={["site-footer", className]}>
	<div class="site-footer__container">
		<div class="site-footer__main">
			<div class="site-footer__brand">
				<SiteLogo
					size="md"
					showTagline={true}
					idPrefix={logoIdPrefix}
				/>

				<p>{site.description}</p>

				<a
					class="site-footer__primary-action"
					href={whatsappUrl}
					target="_blank"
					rel="noopener noreferrer"
				>
					Falar pelo WhatsApp

					<svg
						viewBox="0 0 20 20"
						aria-hidden="true"
						focusable="false"
					>
						<path
							d="M6 14L14 6M8 6h6v6"
							fill="none"
							stroke="currentColor"
							stroke-width="1.7"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</a>
			</div>

			<div class="site-footer__column">
				<span class="site-footer__column-title">
					Navegação
				</span>

				<nav aria-label="Navegação do rodapé">
					{
						navigation.map((item) => (
							<a
								href={item.href}
								target={
									item.external
										? "_blank"
										: undefined
								}
								rel={
									item.external
										? "noopener noreferrer"
										: undefined
								}
							>
								{item.label}
							</a>
						))
					}
				</nav>
			</div>

			<div class="site-footer__column">
				<span class="site-footer__column-title">
					Contato
				</span>

				<div class="site-footer__links">
					<a href={phoneHref}>
						{site.phone}
					</a>

					{
						site.email && (
							<a href={`mailto:${site.email}`}>
								{site.email}
							</a>
						)
					}

					<a
						href={whatsappUrl}
						target="_blank"
						rel="noopener noreferrer"
					>
						WhatsApp
					</a>

					{
						socialLinks.map((item) => (
							<a
								href={item.href}
								target="_blank"
								rel="noopener noreferrer"
							>
								{item.label}
							</a>
						))
					}
				</div>
			</div>

			<div class="site-footer__column site-footer__area">
				<span class="site-footer__column-title">
					Atendimento
				</span>

				{
					site.address && (
						<p>{site.address}</p>
					)
				}

				<p>{serviceAreaText}</p>

				<span class="site-footer__status">
					<span aria-hidden="true"></span>
					{site.serviceHours}
				</span>
			</div>
		</div>

		<div class="site-footer__bottom">
			<p>
				© {currentYear} {site.legalName}.
			</p>

			<p>
				Tecnologia que conecta.
			</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		width: 100%;
		margin-top: 80px;
		border-top: 1px solid rgba(105, 142, 196, 0.14);
		background:
			radial-gradient(
				circle at 10% 0%,
				rgba(56, 91, 211, 0.11),
				transparent 30%
			),
			#03070d;
		color: #ffffff;
	}

	.site-footer__container {
		width: min(100% - 40px, 1120px);
		margin: 0 auto;
	}

	.site-footer__main {
		display: grid;
		grid-template-columns: minmax(250px, 1.45fr) repeat(3, 1fr);
		gap: 52px;
		padding: 68px 0 58px;
	}

	.site-footer__brand {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
	}

	.site-footer__brand > p {
		max-width: 330px;
		margin: 24px 0 0;
		color: #8899b0;
		font-size: 0.84rem;
		line-height: 1.7;
	}

	.site-footer__primary-action {
		display: inline-flex;
		min-height: 44px;
		margin-top: 24px;
		padding: 0 16px;
		align-items: center;
		justify-content: center;
		gap: 9px;
		border: 1px solid rgba(91, 149, 235, 0.26);
		border-radius: 12px;
		background: rgba(37, 101, 204, 0.14);
		color: #f7faff;
		font-size: 0.71rem;
		font-weight: 600;
		text-decoration: none;
		transition:
			border-color 180ms ease,
			background-color 180ms ease,
			transform 180ms ease;
	}

	.site-footer__primary-action svg {
		width: 17px;
		height: 17px;
	}

	.site-footer__primary-action:hover {
		border-color: rgba(69, 151, 255, 0.55);
		background: rgba(39, 111, 226, 0.23);
		transform: translateY(-1px);
	}

	.site-footer__column {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
	}

	.site-footer__column-title {
		margin-bottom: 21px;
		color: #718bb0;
		font-size: 0.57rem;
		font-weight: 600;
		letter-spacing: 0.21em;
		text-transform: uppercase;
	}

	.site-footer__column nav,
	.site-footer__links {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
		gap: 14px;
	}

	.site-footer__column a {
		color: #a4b0c1;
		font-size: 0.76rem;
		line-height: 1.4;
		text-decoration: none;
		transition: color 180ms ease;
	}

	.site-footer__column a:hover {
		color: #ffffff;
	}

	.site-footer__area {
		gap: 10px;
	}

	.site-footer__area p {
		margin: 0;
		color: #9aa8bb;
		font-size: 0.76rem;
		line-height: 1.7;
	}

	.site-footer__status {
		display: inline-flex;
		margin-top: 8px;
		align-items: center;
		gap: 8px;
		color: #8293aa;
		font-size: 0.66rem;
		line-height: 1.5;
	}

	.site-footer__status > span {
		width: 7px;
		height: 7px;
		flex-shrink: 0;
		border-radius: 999px;
		background: #23d49b;
		box-shadow: 0 0 12px rgba(35, 212, 155, 0.55);
	}

	.site-footer__bottom {
		display: flex;
		min-height: 68px;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		border-top: 1px solid rgba(105, 142, 196, 0.11);
	}

	.site-footer__bottom p {
		margin: 0;
		color: #65758c;
		font-size: 0.64rem;
		letter-spacing: 0.035em;
	}

	.site-footer a:focus-visible {
		border-radius: 6px;
		outline: 2px solid rgba(70, 147, 255, 0.75);
		outline-offset: 4px;
	}

	@media (max-width: 900px) {
		.site-footer__main {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 600px) {
		.site-footer {
			margin-top: 60px;
		}

		.site-footer__container {
			width: min(100% - 28px, 1120px);
		}

		.site-footer__main {
			grid-template-columns: 1fr;
			gap: 42px;
			padding: 52px 0 44px;
		}

		.site-footer__bottom {
			min-height: auto;
			padding: 22px 0;
			align-items: flex-start;
			flex-direction: column;
			gap: 8px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.site-footer__primary-action,
		.site-footer__column a {
			transition: none;
		}
	}
</style>
