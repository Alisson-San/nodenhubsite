---
import SiteLogo from "./SiteLogo.astro";

import {
	getWhatsAppUrl,
	siteConfig as fallbackSiteConfig,
} from "../../config/site";

import type {
	RuntimeSiteConfig,
} from "../../types/site";

interface NavigationItem {
	label: string;
	href: string;
	external?: boolean;
}

interface Props {
	site?: RuntimeSiteConfig;
	navigation?: NavigationItem[];
	sticky?: boolean;
	logoHref?: string;
	logoIdPrefix?: string;
	ctaLabel?: string;
	ctaHref?: string;
	currentPath?: string;
	class?: string;
}

const defaultNavigation: NavigationItem[] = [
	{
		label: "Início",
		href: "/",
	},
	{
		label: "Noden Home",
		href: "/home",
	},
	{
		label: "Noden Game",
		href: "/game",
	},
	{
		label: "Noden Data",
		href: "/data",
	},
];

const {
	site = fallbackSiteConfig,
	navigation = defaultNavigation,
	sticky = true,
	logoHref = "/",
	logoIdPrefix = "site-header-logo",
	ctaLabel = "Falar com a Noden",
	ctaHref,
	currentPath = Astro.url.pathname,
	class: className = "",
} = Astro.props;

const resolvedCtaHref =
	ctaHref ??
	getWhatsAppUrl(
		undefined,
		site,
	);

const normalizePath = (path: string) => {
	if (path === "/") {
		return "/";
	}

	return path.replace(/\/+$/, "");
};

const normalizedCurrentPath = normalizePath(currentPath);

const isActive = (href: string) => {
	if (
		href.startsWith("#") ||
		href.startsWith("http://") ||
		href.startsWith("https://")
	) {
		return false;
	}

	const normalizedHref = normalizePath(href);

	if (normalizedHref === "/") {
		return normalizedCurrentPath === "/";
	}

	return (
		normalizedCurrentPath === normalizedHref ||
		normalizedCurrentPath.startsWith(`${normalizedHref}/`)
	);
};

const ctaExternal =
	resolvedCtaHref.startsWith("http://") ||
	resolvedCtaHref.startsWith("https://");
---

<header
	class:list={["site-header", className]}
	data-site-header
	data-sticky={sticky ? "true" : "false"}
>
	<div class="site-header__container">
		<SiteLogo
			size="sm"
			href={logoHref}
			idPrefix={logoIdPrefix}
		/>

		<nav
			class="site-header__desktop-navigation"
			aria-label="Navegação principal"
		>
			{
				navigation.map((item) => (
					<a
						class:list={[
							"site-header__navigation-link",
							{
								"is-active": isActive(item.href),
							},
						]}
						href={item.href}
						target={item.external ? "_blank" : undefined}
						rel={item.external ? "noopener noreferrer" : undefined}
						aria-current={
							isActive(item.href)
								? "page"
								: undefined
						}
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<a
			class="site-header__cta site-header__desktop-cta"
			href={resolvedCtaHref}
			target={ctaExternal ? "_blank" : undefined}
			rel={ctaExternal ? "noopener noreferrer" : undefined}
		>
			{ctaLabel}

			<svg
				viewBox="0 0 20 20"
				aria-hidden="true"
				focusable="false"
			>
				<path
					d="M6 14L14 6M8 6h6v6"
					fill="none"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</svg>
		</a>

		<details class="site-header__mobile-menu">
			<summary aria-label="Abrir menu de navegação">
				<span class="site-header__menu-icon" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</span>
			</summary>

			<div class="site-header__mobile-panel">
				<nav aria-label="Navegação mobile">
					{
						navigation.map((item) => (
							<a
								class:list={[
									"site-header__mobile-link",
									{
										"is-active": isActive(item.href),
									},
								]}
								href={item.href}
								target={
									item.external
										? "_blank"
										: undefined
								}
								rel={
									item.external
										? "noopener noreferrer"
										: undefined
								}
								aria-current={
									isActive(item.href)
										? "page"
										: undefined
								}
							>
								<span>{item.label}</span>

								<svg
									viewBox="0 0 20 20"
									aria-hidden="true"
								>
									<path
										d="M6 14L14 6M8 6h6v6"
										fill="none"
										stroke="currentColor"
										stroke-width="1.6"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</a>
						))
					}
				</nav>

				<a
					class="site-header__cta site-header__mobile-cta"
					href={resolvedCtaHref}
					target={ctaExternal ? "_blank" : undefined}
					rel={ctaExternal ? "noopener noreferrer" : undefined}
				>
					{ctaLabel}

					<svg
						viewBox="0 0 20 20"
						aria-hidden="true"
					>
						<path
							d="M6 14L14 6M8 6h6v6"
							fill="none"
							stroke="currentColor"
							stroke-width="1.7"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</a>
			</div>
		</details>
	</div>
</header>

<script>
	const headers =
		document.querySelectorAll<HTMLElement>("[data-site-header]");

	headers.forEach((header) => {
		const mobileMenu =
			header.querySelector<HTMLDetailsElement>(
				".site-header__mobile-menu",
			);

		if (!mobileMenu) {
			return;
		}

		const summary = mobileMenu.querySelector("summary");

		const updateSummaryLabel = () => {
			summary?.setAttribute(
				"aria-label",
				mobileMenu.open
					? "Fechar menu de navegação"
					: "Abrir menu de navegação",
			);
		};

		mobileMenu.addEventListener("toggle", updateSummaryLabel);

		mobileMenu
			.querySelectorAll<HTMLAnchorElement>("a")
			.forEach((link) => {
				link.addEventListener("click", () => {
					mobileMenu.removeAttribute("open");
				});
			});

		mobileMenu.addEventListener("keydown", (event) => {
			if (event.key !== "Escape") {
				return;
			}

			mobileMenu.removeAttribute("open");
			summary?.focus();
		});

		updateSummaryLabel();
	});
</script>

<style>
	.site-header {
		position: relative;
		z-index: 50;
		width: 100%;
		border-bottom: 1px solid rgba(113, 148, 201, 0.12);
		background: rgba(2, 6, 13, 0.82);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.site-header[data-sticky="true"] {
		position: sticky;
		top: 0;
	}

	.site-header__container {
		display: flex;
		width: min(100% - 40px, 1120px);
		min-height: 72px;
		margin: 0 auto;
		align-items: center;
		gap: 30px;
	}

	.site-header__desktop-navigation {
		display: flex;
		margin-left: auto;
		align-items: center;
		gap: 6px;
	}

	.site-header__navigation-link {
		position: relative;
		padding: 10px 12px;
		border-radius: 10px;
		color: #8797ad;
		font-size: 0.73rem;
		font-weight: 500;
		letter-spacing: 0.035em;
		text-decoration: none;
		transition:
			color 180ms ease,
			background-color 180ms ease;
	}

	.site-header__navigation-link:hover {
		color: #f5f8ff;
		background: rgba(93, 132, 192, 0.08);
	}

	.site-header__navigation-link.is-active {
		color: #ffffff;
	}

	.site-header__navigation-link.is-active::after {
		position: absolute;
		right: 12px;
		bottom: 4px;
		left: 12px;
		height: 1px;
		border-radius: 999px;
		background: linear-gradient(
			90deg,
			#6f35ff,
			#2387ff,
			#15d5ef
		);
		content: "";
	}

	.site-header__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 9px;
		border: 1px solid rgba(99, 152, 227, 0.26);
		border-radius: 12px;
		background: rgba(30, 88, 177, 0.14);
		color: #f7faff;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.035em;
		text-decoration: none;
		transition:
			border-color 180ms ease,
			background-color 180ms ease,
			transform 180ms ease;
	}

	.site-header__desktop-cta {
		min-height: 40px;
		padding: 0 15px;
	}

	.site-header__cta svg {
		width: 17px;
		height: 17px;
		flex-shrink: 0;
	}

	.site-header__cta:hover {
		border-color: rgba(76, 155, 255, 0.52);
		background: rgba(30, 100, 211, 0.23);
		transform: translateY(-1px);
	}

	.site-header__navigation-link:focus-visible,
	.site-header__cta:focus-visible,
	.site-header__mobile-menu summary:focus-visible,
	.site-header__mobile-link:focus-visible {
		outline: 2px solid rgba(70, 147, 255, 0.75);
		outline-offset: 3px;
	}

	.site-header__mobile-menu {
		position: relative;
		display: none;
		margin-left: auto;
	}

	.site-header__mobile-menu summary {
		display: flex;
		width: 42px;
		height: 42px;
		cursor: pointer;
		list-style: none;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(113, 148, 201, 0.2);
		border-radius: 12px;
		background: rgba(11, 23, 41, 0.76);
	}

	.site-header__mobile-menu summary::-webkit-details-marker {
		display: none;
	}

	.site-header__menu-icon {
		display: flex;
		width: 17px;
		flex-direction: column;
		gap: 4px;
	}

	.site-header__menu-icon span {
		display: block;
		width: 100%;
		height: 1.5px;
		border-radius: 999px;
		background: #ffffff;
		transition:
			transform 180ms ease,
			opacity 180ms ease;
	}

	.site-header__mobile-menu[open]
		.site-header__menu-icon span:first-child {
		transform: translateY(5.5px) rotate(45deg);
	}

	.site-header__mobile-menu[open]
		.site-header__menu-icon span:nth-child(2) {
		opacity: 0;
	}

	.site-header__mobile-menu[open]
		.site-header__menu-icon span:last-child {
		transform: translateY(-5.5px) rotate(-45deg);
	}

	.site-header__mobile-panel {
		position: absolute;
		top: calc(100% + 12px);
		right: 0;
		width: min(320px, calc(100vw - 32px));
		padding: 12px;
		border: 1px solid rgba(107, 145, 201, 0.18);
		border-radius: 18px;
		background:
			linear-gradient(
				180deg,
				rgba(13, 28, 50, 0.98),
				rgba(5, 12, 23, 0.98)
			);
		box-shadow: 0 24px 60px rgba(0, 0, 0, 0.42);
	}

	.site-header__mobile-panel nav {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.site-header__mobile-link {
		display: flex;
		min-height: 48px;
		padding: 0 13px;
		align-items: center;
		justify-content: space-between;
		border-radius: 11px;
		color: #a4b0c1;
		font-size: 0.78rem;
		font-weight: 500;
		text-decoration: none;
	}

	.site-header__mobile-link svg {
		width: 17px;
		height: 17px;
		opacity: 0.45;
	}

	.site-header__mobile-link:hover,
	.site-header__mobile-link.is-active {
		background: rgba(69, 119, 196, 0.11);
		color: #ffffff;
	}

	.site-header__mobile-cta {
		min-height: 48px;
		margin-top: 10px;
		padding: 0 15px;
	}

	@media (max-width: 860px) {
		.site-header__container {
			width: min(100% - 28px, 1120px);
			min-height: 66px;
		}

		.site-header__desktop-navigation,
		.site-header__desktop-cta {
			display: none;
		}

		.site-header__mobile-menu {
			display: block;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.site-header__navigation-link,
		.site-header__cta,
		.site-header__menu-icon span {
			transition: none;
		}
	}
</style>
